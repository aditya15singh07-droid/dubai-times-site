---
import { categories, categoryPath } from "../data/articles";
import { seoTopics, topicPath } from "../data/topics";

type Props = {
  title?: string;
  description?: string;
  robots?: string;
  canonical?: string;
  type?: string;
  structuredData?: Record<string, unknown> | Record<string, unknown>[];
};

const {
  title = "Dubai Time",
  description = "Dubai Time tracks the UAE clock, emirates weather, alerts, and the stories shaping Dubai and the wider UAE.",
  robots = "index, follow",
  canonical,
  type = "website",
  structuredData,
} = Astro.props;

const siteUrl = "https://dubai-time.com";
const canonicalUrl = canonical || new URL(Astro.url.pathname, siteUrl).toString();
const baseStructuredData = [
  {
    "@context": "https://schema.org",
    "@type": "NewsMediaOrganization",
    name: "Dubai Time",
    url: siteUrl,
    logo: `${siteUrl}/favicon.svg`,
    description:
      "Dubai Time publishes live UAE time, seven-emirate weather, market context, and UAE-focused business and lifestyle news.",
    sameAs: [siteUrl],
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: "Dubai Time",
    url: siteUrl,
    potentialAction: {
      "@type": "SearchAction",
      target: `${siteUrl}/?q={search_term_string}`,
      "query-input": "required name=search_term_string",
    },
  },
];
const pageStructuredData = structuredData
  ? Array.isArray(structuredData)
    ? structuredData
    : [structuredData]
  : [];
const jsonLd = JSON.stringify([...baseStructuredData, ...pageStructuredData]).replaceAll("</script", "<\\/script");

const primaryLinks = [
  { href: "/", label: "Time" },
  { href: "/#weather", label: "Weather" },
  { href: "/#news", label: "News" },
  { href: "/about", label: "About" },
];

const desktopLinks = [
  ...primaryLinks.slice(0, 3),
  ...categories.map((category) => ({
    href: `/category/${categoryPath(category)}`,
    label: category,
  })),
  primaryLinks[3],
];
---

<!doctype html>
<html lang="en">
  <head>
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-W2YNPGHLFX"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag("js", new Date());

      gtag("config", "G-W2YNPGHLFX");
    </script>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="robots" content={robots} />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" type="application/rss+xml" title="Dubai Time RSS" href={`${siteUrl}/rss.xml`} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="Dubai Time" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <script type="application/ld+json" set:html={jsonLd}></script>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <title>{title}</title>
  </head>
  <body>
    <div class="topline">
      <span>Dubai Time</span>
      <span>UAE clock, markets, weather and business context</span>
    </div>
    <header class="site-header">
      <div class="mobile-header-row">
        <button
          class="menu-toggle"
          type="button"
          aria-label="Open menu"
          aria-controls="mobile-menu"
          aria-expanded="false"
          data-menu-toggle
        >
          <span></span>
          <span></span>
          <span></span>
        </button>
        <a class="brand" href="/" aria-label="Dubai Time home">
          <span>Dubai</span>
          <strong>Time</strong>
        </a>
      </div>
      <nav class="nav desktop-nav" aria-label="Main navigation">
        {desktopLinks.map((link) => <a href={link.href}>{link.label}</a>)}
      </nav>
      <div class="mobile-menu" id="mobile-menu" data-mobile-menu hidden>
        <nav class="mobile-nav" aria-label="Mobile navigation">
          <a href="/">Home</a>
          <a href="/#weather">Weather</a>
          <a href="/#news">News</a>
          <button
            class="category-toggle"
            type="button"
            aria-controls="mobile-categories"
            aria-expanded="false"
            data-category-toggle
          >
            <span>Categories</span>
            <i aria-hidden="true"></i>
          </button>
          <div class="mobile-categories" id="mobile-categories" data-mobile-categories hidden>
            {categories.map((category) => <a href={`/category/${categoryPath(category)}`}>{category}</a>)}
          </div>
          <a href="/about">About</a>
        </nav>
        <p>Live UAE time, seven-emirate weather, markets and category-led news context.</p>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <div>
        <strong>Dubai Time</strong>
        <p>UAE time, emirates weather, alerts, and independent news context.</p>
      </div>
      <nav class="footer-topics" aria-label="Topic hubs">
        {seoTopics.map((topic) => <a href={topicPath(topic.slug)}>{topic.title}</a>)}
      </nav>
      <p class="footer-note">Built as the first foundation for the Dubai Time publishing system.</p>
    </footer>
    <script is:inline>
      const menuToggle = document.querySelector("[data-menu-toggle]");
      const mobileMenu = document.querySelector("[data-mobile-menu]");
      const categoryToggle = document.querySelector("[data-category-toggle]");
      const mobileCategories = document.querySelector("[data-mobile-categories]");

      function setMenuOpen(isOpen) {
        if (!menuToggle || !mobileMenu) return;
        menuToggle.setAttribute("aria-expanded", String(isOpen));
        menuToggle.classList.toggle("is-open", isOpen);
        mobileMenu.hidden = !isOpen;
      }

      function setCategoriesOpen(isOpen) {
        if (!categoryToggle || !mobileCategories) return;
        categoryToggle.setAttribute("aria-expanded", String(isOpen));
        categoryToggle.classList.toggle("is-open", isOpen);
        mobileCategories.hidden = !isOpen;
      }

      menuToggle?.addEventListener("click", () => {
        const isOpen = menuToggle.getAttribute("aria-expanded") === "true";
        setMenuOpen(!isOpen);
      });

      categoryToggle?.addEventListener("click", () => {
        const isOpen = categoryToggle.getAttribute("aria-expanded") === "true";
        setCategoriesOpen(!isOpen);
      });

      mobileMenu?.querySelectorAll("a").forEach((link) => {
        link.addEventListener("click", () => {
          setMenuOpen(false);
          setCategoriesOpen(false);
        });
      });

      document.addEventListener("keydown", (event) => {
        if (event.key === "Escape") {
          setMenuOpen(false);
          setCategoriesOpen(false);
        }
      });
    </script>
  </body>
</html>

<style is:global>
  :root {
    color-scheme: light;
    --ink: #111214;
    --muted: #62636a;
    --soft: #8a8c94;
    --line: #e4e1dc;
    --paper: #f7f5ef;
    --panel: #ffffff;
    --accent: #e33b2f;
    --accent-strong: #143c46;
    --gold: #b9892f;
    --cream: #fffaf1;
    --shadow: 0 18px 54px rgba(17, 18, 20, 0.08);
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
      sans-serif;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    background: var(--paper);
    color: var(--ink);
    font-size: 15px;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  img {
    display: block;
    width: 100%;
  }

  .topline {
    align-items: center;
    background: #111214;
    color: rgba(255, 255, 255, 0.74);
    display: flex;
    font-size: 0.76rem;
    font-weight: 800;
    justify-content: space-between;
    letter-spacing: 0.06em;
    padding: 9px max(22px, calc((100vw - 1180px) / 2 + 24px));
    text-transform: uppercase;
  }

  .topline span:first-child {
    color: #fff;
  }

  .site-header {
    align-items: center;
    background: rgba(255, 250, 241, 0.96);
    border-bottom: 1px solid var(--line);
    display: flex;
    gap: 24px;
    justify-content: space-between;
    margin: 0 auto;
    padding: 20px max(22px, calc((100vw - 1180px) / 2 + 24px)) 18px;
    position: sticky;
    top: 0;
    z-index: 30;
  }

  .mobile-header-row {
    display: contents;
  }

  .menu-toggle,
  .mobile-menu {
    display: none;
  }

  .brand {
    align-items: baseline;
    display: flex;
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
      sans-serif;
    font-size: clamp(1.75rem, 3vw, 2.7rem);
    font-weight: 950;
    gap: 10px;
    letter-spacing: -0.038em;
    line-height: 1.05;
    padding-bottom: 4px;
  }

  .brand span {
    color: #101214;
  }

  .brand strong {
    background: linear-gradient(135deg, #e33b2f 0%, #c28b2c 58%, #143c46 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    display: inline-block;
    font-weight: 950;
    padding-bottom: 0.06em;
  }

  .nav {
    display: flex;
    flex-wrap: wrap;
    gap: 10px 16px;
    justify-content: flex-end;
  }

  .nav a {
    color: #34363c;
    font-size: 0.68rem;
    font-weight: 900;
    letter-spacing: 0.03em;
    padding: 7px 0;
    text-transform: uppercase;
  }

  .nav a:hover {
    color: var(--accent);
  }

  .mobile-menu[hidden],
  .mobile-categories[hidden] {
    display: none !important;
  }

  .section {
    margin: 0 auto;
    max-width: 1180px;
    padding: 30px 24px;
  }

  .eyebrow {
    color: var(--accent);
    font-size: 0.78rem;
    font-weight: 900;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  main p:not(.eyebrow) {
    hyphens: none;
    overflow-wrap: normal;
    text-align: justify;
    text-justify: inter-word;
    word-break: normal;
  }

  .site-footer {
    background: #111214;
    border-top: 5px solid var(--accent);
    color: var(--muted);
    display: flex;
    gap: 24px;
    justify-content: space-between;
    margin: 54px 0 0;
    padding: 34px max(22px, calc((100vw - 1180px) / 2 + 24px)) 42px;
  }

  .site-footer strong {
    color: #fff;
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
      sans-serif;
    font-size: 1.05rem;
  }

  .site-footer p {
    margin: 8px 0 0;
  }

  .footer-note {
    max-width: 360px;
    text-align: right;
  }

  .footer-topics {
    display: flex;
    flex-wrap: wrap;
    gap: 10px 16px;
    justify-content: center;
    max-width: 430px;
  }

  .footer-topics a {
    color: rgba(255, 255, 255, 0.72);
    font-size: 0.72rem;
    font-weight: 900;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .footer-topics a:hover {
    color: #fff;
  }

  @media (max-width: 760px) {
    .topline {
      align-items: flex-start;
      flex-direction: column;
      font-size: 0.64rem;
      gap: 3px;
      letter-spacing: 0.045em;
      line-height: 1.25;
      padding: 8px 18px;
    }

    .site-header,
    .site-footer {
      align-items: flex-start;
      flex-direction: column;
    }

    .site-header {
      gap: 14px;
      padding: 18px;
      position: relative;
    }

    .mobile-header-row {
      align-items: center;
      display: flex;
      gap: 14px;
      justify-content: flex-start;
      width: 100%;
    }

    .menu-toggle {
      align-items: center;
      appearance: none;
      background: transparent;
      border: 0;
      cursor: pointer;
      display: inline-flex;
      flex: 0 0 auto;
      flex-direction: column;
      gap: 5px;
      height: 40px;
      justify-content: center;
      margin: 0;
      padding: 0;
      width: 40px;
    }

    .menu-toggle span {
      background: #101214;
      border-radius: 999px;
      box-shadow: 0 0 0 1px rgba(227, 59, 47, 0.04);
      display: block;
      height: 3px;
      transition:
        transform 180ms ease,
        opacity 180ms ease,
        background 180ms ease;
      width: 27px;
    }

    .menu-toggle.is-open span {
      background: var(--accent);
    }

    .menu-toggle.is-open span:nth-child(1) {
      transform: translateY(8px) rotate(45deg);
    }

    .menu-toggle.is-open span:nth-child(2) {
      opacity: 0;
    }

    .menu-toggle.is-open span:nth-child(3) {
      transform: translateY(-8px) rotate(-45deg);
    }

    .brand {
      font-size: clamp(1.95rem, 10vw, 2.7rem);
      gap: 7px;
      line-height: 1;
    }

    .desktop-nav {
      display: none;
    }

    .mobile-menu:not([hidden]) {
      background: rgba(255, 250, 241, 0.98);
      border: 1px solid rgba(17, 18, 20, 0.08);
      box-shadow: 0 24px 60px rgba(17, 18, 20, 0.12);
      display: block;
      padding: 16px;
      width: 100%;
    }

    .mobile-nav {
      display: grid;
      gap: 10px;
    }

    .mobile-nav > a,
    .category-toggle {
      align-items: center;
      background: #fff;
      border: 1px solid var(--line);
      color: #111214;
      display: flex;
      font: inherit;
      font-size: 0.92rem;
      font-weight: 900;
      justify-content: space-between;
      letter-spacing: 0.02em;
      line-height: 1;
      min-height: 48px;
      padding: 0 16px;
      text-transform: uppercase;
      width: 100%;
    }

    .category-toggle {
      appearance: none;
      cursor: pointer;
    }

    .category-toggle i {
      border-left: 7px solid transparent;
      border-right: 7px solid transparent;
      border-top: 8px solid #111214;
      display: block;
      height: 0;
      transition: transform 180ms ease;
      width: 0;
    }

    .category-toggle.is-open i {
      transform: rotate(180deg);
    }

    .mobile-categories {
      display: grid;
      gap: 8px;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      padding: 2px 0 4px;
    }

    .mobile-categories a {
      background: rgba(17, 18, 20, 0.045);
      border: 1px solid rgba(17, 18, 20, 0.08);
      color: #303238;
      font-size: 0.74rem;
      font-weight: 900;
      letter-spacing: 0.02em;
      min-height: 40px;
      padding: 13px 10px;
      text-align: center;
      text-transform: uppercase;
    }

    .mobile-menu p {
      color: var(--muted);
      font-size: 0.82rem;
      font-weight: 750;
      line-height: 1.5;
      margin: 14px 0 0;
      text-align: left;
    }

    .footer-note {
      text-align: left;
    }

    .footer-topics {
      justify-content: flex-start;
    }
  }

  @media (max-width: 420px) {
    .mobile-categories {
      grid-template-columns: 1fr;
    }
  }
</style>
