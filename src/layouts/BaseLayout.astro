---
type Props = {
  title?: string;
  description?: string;
};

const {
  title = "Dubai Time",
  description = "Dubai Time tracks the UAE clock, emirates weather, alerts, and the stories shaping Dubai and the wider UAE.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="robots" content="noindex, nofollow, noarchive, nosnippet" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="/" aria-label="Dubai Time home">
        <span>Dubai</span>
        <strong>Time</strong>
      </a>
      <nav class="nav" aria-label="Main navigation">
        <a href="/">Time</a>
        <a href="/#weather">Weather</a>
        <a href="/#news">News</a>
        <a href="/category/dubai">Dubai</a>
        <a href="/category/business">Business</a>
        <a href="/about">About</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <div>
        <strong>Dubai Time</strong>
        <p>UAE time, emirates weather, alerts, and independent news context.</p>
      </div>
      <p class="footer-note">Built as the first foundation for the Dubai Time publishing system.</p>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    color-scheme: light;
    --ink: #171717;
    --muted: #62666f;
    --line: #ded8cd;
    --paper: #fbfaf7;
    --panel: #ffffff;
    --accent: #0b6e69;
    --accent-strong: #084c61;
    --gold: #c2912d;
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
      sans-serif;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    background:
      linear-gradient(180deg, rgba(251, 250, 247, 0.96), rgba(244, 241, 233, 0.96)),
      linear-gradient(135deg, rgba(8, 76, 97, 0.08), rgba(194, 145, 45, 0.07));
    color: var(--ink);
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  img {
    display: block;
    width: 100%;
  }

  .site-header {
    align-items: center;
    backdrop-filter: blur(22px) saturate(1.18);
    background:
      linear-gradient(135deg, rgba(255, 255, 255, 0.84), rgba(251, 250, 247, 0.68));
    border: 1px solid rgba(255, 255, 255, 0.56);
    border-bottom-color: rgba(222, 216, 205, 0.78);
    border-radius: 0 0 10px 10px;
    box-shadow: 0 18px 50px rgba(7, 19, 24, 0.08);
    display: flex;
    gap: 28px;
    justify-content: space-between;
    margin: 0 auto;
    max-width: 1180px;
    padding: 22px 24px;
    position: sticky;
    top: 0;
    z-index: 10;
  }

  .brand {
    align-items: baseline;
    display: flex;
    font-family: Georgia, "Times New Roman", serif;
    font-size: clamp(2rem, 5vw, 4rem);
    gap: 8px;
    line-height: 0.9;
  }

  .brand span {
    color: var(--accent-strong);
  }

  .brand strong {
    color: var(--gold);
    font-weight: 700;
  }

  .nav {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    justify-content: flex-end;
  }

  .nav a {
    border-bottom: 2px solid transparent;
    color: var(--muted);
    font-size: 0.9rem;
    font-weight: 700;
    padding: 8px 0;
  }

  .nav a:hover {
    border-color: var(--gold);
    color: var(--ink);
  }

  .section {
    margin: 0 auto;
    max-width: 1180px;
    padding: 34px 24px;
  }

  .eyebrow {
    color: var(--accent);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .site-footer {
    border-top: 1px solid var(--line);
    color: var(--muted);
    display: flex;
    gap: 24px;
    justify-content: space-between;
    margin: 42px auto 0;
    max-width: 1180px;
    padding: 28px 24px 40px;
  }

  .site-footer strong {
    color: var(--ink);
    font-family: Georgia, "Times New Roman", serif;
    font-size: 1.5rem;
  }

  .site-footer p {
    margin: 8px 0 0;
  }

  .footer-note {
    max-width: 360px;
    text-align: right;
  }

  @media (max-width: 760px) {
    .site-header,
    .site-footer {
      align-items: flex-start;
      flex-direction: column;
    }

    .site-header {
      gap: 18px;
      padding: 24px 24px 20px;
      position: relative;
    }

    .nav {
      gap: 18px;
      justify-content: flex-start;
      overflow-x: auto;
      padding-bottom: 4px;
      scrollbar-width: none;
      white-space: nowrap;
      width: 100%;
    }

    .nav::-webkit-scrollbar {
      display: none;
    }

    .footer-note {
      text-align: left;
    }
  }
</style>
