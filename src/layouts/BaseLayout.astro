---
type Props = {
  title?: string;
  description?: string;
};

const {
  title = "Dubai Time",
  description = "Dubai Time tracks the UAE clock, emirates weather, alerts, and the stories shaping Dubai and the wider UAE.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="robots" content="noindex, nofollow, noarchive, nosnippet" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <title>{title}</title>
  </head>
  <body>
    <div class="topline">
      <span>Dubai Time</span>
      <span>UAE clock, markets, weather and business context</span>
    </div>
    <header class="site-header">
      <a class="brand" href="/" aria-label="Dubai Time home">
        <span>Dubai</span>
        <strong>Time</strong>
      </a>
      <nav class="nav" aria-label="Main navigation">
        <a href="/">Time</a>
        <a href="/#weather">Weather</a>
        <a href="/#news">News</a>
        <a href="/category/business">Business</a>
        <a href="/category/real-estate">Real Estate</a>
        <a href="/category/travel">Travel</a>
        <a href="/category/crypto">Crypto</a>
        <a href="/category/middle-east">Middle East</a>
        <a href="/about">About</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <div>
        <strong>Dubai Time</strong>
        <p>UAE time, emirates weather, alerts, and independent news context.</p>
      </div>
      <p class="footer-note">Built as the first foundation for the Dubai Time publishing system.</p>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    color-scheme: light;
    --ink: #111214;
    --muted: #62636a;
    --soft: #8a8c94;
    --line: #e4e1dc;
    --paper: #f7f5ef;
    --panel: #ffffff;
    --accent: #e33b2f;
    --accent-strong: #143c46;
    --gold: #b9892f;
    --cream: #fffaf1;
    --shadow: 0 18px 54px rgba(17, 18, 20, 0.08);
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
      sans-serif;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    background: var(--paper);
    color: var(--ink);
    font-size: 15px;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  img {
    display: block;
    width: 100%;
  }

  .topline {
    align-items: center;
    background: #111214;
    color: rgba(255, 255, 255, 0.74);
    display: flex;
    font-size: 0.76rem;
    font-weight: 800;
    justify-content: space-between;
    letter-spacing: 0.06em;
    padding: 9px max(22px, calc((100vw - 1180px) / 2 + 24px));
    text-transform: uppercase;
  }

  .topline span:first-child {
    color: #fff;
  }

  .site-header {
    align-items: center;
    background: rgba(255, 250, 241, 0.96);
    border-bottom: 1px solid var(--line);
    display: flex;
    gap: 28px;
    justify-content: space-between;
    margin: 0 auto;
    padding: 20px max(22px, calc((100vw - 1180px) / 2 + 24px)) 18px;
    position: sticky;
    top: 0;
    z-index: 30;
  }

  .brand {
    align-items: baseline;
    display: flex;
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
      sans-serif;
    font-size: clamp(1.75rem, 3vw, 2.7rem);
    font-weight: 950;
    gap: 10px;
    letter-spacing: -0.038em;
    line-height: 1.05;
    padding-bottom: 4px;
  }

  .brand span {
    color: #101214;
  }

  .brand strong {
    background: linear-gradient(135deg, #e33b2f 0%, #c28b2c 58%, #143c46 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    display: inline-block;
    font-weight: 950;
    padding-bottom: 0.06em;
  }

  .nav {
    display: flex;
    flex-wrap: wrap;
    gap: 18px;
    justify-content: flex-end;
  }

  .nav a {
    color: #34363c;
    font-size: 0.76rem;
    font-weight: 900;
    letter-spacing: 0.04em;
    padding: 8px 0;
    text-transform: uppercase;
  }

  .nav a:hover {
    color: var(--accent);
  }

  .section {
    margin: 0 auto;
    max-width: 1180px;
    padding: 30px 24px;
  }

  .eyebrow {
    color: var(--accent);
    font-size: 0.78rem;
    font-weight: 900;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  main p:not(.eyebrow) {
    hyphens: none;
    overflow-wrap: normal;
    text-align: justify;
    text-justify: inter-word;
    word-break: normal;
  }

  .site-footer {
    background: #111214;
    border-top: 5px solid var(--accent);
    color: var(--muted);
    display: flex;
    gap: 24px;
    justify-content: space-between;
    margin: 54px 0 0;
    padding: 34px max(22px, calc((100vw - 1180px) / 2 + 24px)) 42px;
  }

  .site-footer strong {
    color: #fff;
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
      sans-serif;
    font-size: 1.05rem;
  }

  .site-footer p {
    margin: 8px 0 0;
  }

  .footer-note {
    max-width: 360px;
    text-align: right;
  }

  @media (max-width: 760px) {
    .topline {
      align-items: flex-start;
      flex-direction: column;
      font-size: 0.64rem;
      gap: 3px;
      letter-spacing: 0.045em;
      line-height: 1.25;
      padding: 8px 18px;
    }

    .site-header,
    .site-footer {
      align-items: flex-start;
      flex-direction: column;
    }

    .site-header {
      gap: 14px;
      padding: 18px;
      position: relative;
    }

    .brand {
      font-size: clamp(1.95rem, 10vw, 2.7rem);
      gap: 7px;
      line-height: 1;
    }

    .nav {
      display: grid;
      gap: 8px;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      justify-content: flex-start;
      overflow: visible;
      padding-bottom: 0;
      white-space: normal;
      width: 100%;
    }

    .nav a {
      background: rgba(17, 18, 20, 0.045);
      border: 1px solid rgba(17, 18, 20, 0.08);
      border-radius: 999px;
      font-size: 0.66rem;
      letter-spacing: 0.025em;
      line-height: 1;
      padding: 9px 6px;
      text-align: center;
    }

    .footer-note {
      text-align: left;
    }
  }

  @media (max-width: 420px) {
    .nav {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
</style>
