---
type Props = {
  title?: string;
  description?: string;
};

const {
  title = "Dubai Times",
  description = "Dubai Times covers Dubai, UAE business, real estate, travel, lifestyle, technology, and the stories shaping the city.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="/" aria-label="Dubai Times home">
        <span>Dubai</span>
        <strong>Times</strong>
      </a>
      <nav class="nav" aria-label="Main navigation">
        <a href="/category/dubai">Dubai</a>
        <a href="/category/business">Business</a>
        <a href="/category/real-estate">Real Estate</a>
        <a href="/category/travel">Travel</a>
        <a href="/about">About</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <div>
        <strong>Dubai Times</strong>
        <p>Independent digital news for Dubai, the UAE, and the wider region.</p>
      </div>
      <p class="footer-note">Built as the first foundation for the Dubai Times publishing system.</p>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    color-scheme: light;
    --ink: #171717;
    --muted: #62666f;
    --line: #ded8cd;
    --paper: #fbfaf7;
    --panel: #ffffff;
    --accent: #0b6e69;
    --accent-strong: #084c61;
    --gold: #c2912d;
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
      sans-serif;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    background: var(--paper);
    color: var(--ink);
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  img {
    display: block;
    width: 100%;
  }

  .site-header {
    align-items: center;
    border-bottom: 1px solid var(--line);
    display: flex;
    gap: 28px;
    justify-content: space-between;
    margin: 0 auto;
    max-width: 1180px;
    padding: 22px 24px;
  }

  .brand {
    align-items: baseline;
    display: flex;
    font-family: Georgia, "Times New Roman", serif;
    font-size: clamp(2rem, 5vw, 4rem);
    gap: 8px;
    line-height: 0.9;
  }

  .brand span {
    color: var(--accent-strong);
  }

  .brand strong {
    color: var(--gold);
    font-weight: 700;
  }

  .nav {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    justify-content: flex-end;
  }

  .nav a {
    border-bottom: 2px solid transparent;
    color: var(--muted);
    font-size: 0.9rem;
    font-weight: 700;
    padding: 8px 0;
  }

  .nav a:hover {
    border-color: var(--gold);
    color: var(--ink);
  }

  .section {
    margin: 0 auto;
    max-width: 1180px;
    padding: 34px 24px;
  }

  .eyebrow {
    color: var(--accent);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .site-footer {
    border-top: 1px solid var(--line);
    color: var(--muted);
    display: flex;
    gap: 24px;
    justify-content: space-between;
    margin: 42px auto 0;
    max-width: 1180px;
    padding: 28px 24px 40px;
  }

  .site-footer strong {
    color: var(--ink);
    font-family: Georgia, "Times New Roman", serif;
    font-size: 1.5rem;
  }

  .site-footer p {
    margin: 8px 0 0;
  }

  .footer-note {
    max-width: 360px;
    text-align: right;
  }

  @media (max-width: 760px) {
    .site-header,
    .site-footer {
      align-items: flex-start;
      flex-direction: column;
    }

    .nav {
      justify-content: flex-start;
    }

    .footer-note {
      text-align: left;
    }
  }
</style>
