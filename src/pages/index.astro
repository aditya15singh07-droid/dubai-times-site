---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { categories } from "../data/articles";

const articles = (await getCollection("articles", ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const [leadArticle, ...moreArticles] = articles;
const estimateRead = (article) => Math.max(3, Math.round((article.body || "").split(/\s+/).length / 220));

const emirates = [
  { name: "Abu Dhabi", label: "Capital", lat: 24.4539, lon: 54.3773 },
  { name: "Dubai", label: "Business hub", lat: 25.2048, lon: 55.2708 },
  { name: "Sharjah", label: "Culture", lat: 25.3463, lon: 55.4209 },
  { name: "Ajman", label: "Coast", lat: 25.4052, lon: 55.5136 },
  { name: "Fujairah", label: "East coast", lat: 25.1288, lon: 56.3265 },
  { name: "Ras Al Khaimah", label: "Northern emirate", lat: 25.8007, lon: 55.9762 },
  { name: "Umm Al Quwain", label: "Lagoon", lat: 25.5647, lon: 55.5552 },
];

const liveNews = articles.slice(0, 4);
const editorPicks = categories
  .map((category) => articles.find((article) => article.data.category === category))
  .filter(Boolean)
  .slice(0, 4);
---

<BaseLayout
  title="Dubai Time | UAE Clock, Emirates Weather And Dubai News"
  description="Dubai Time shows the live UAE clock, seven-emirate weather, rain outlook, alerts, and curated Dubai news."
>
  <section class="time-hero" aria-label="Live UAE time">
    <div class="section time-grid">
      <div class="clock-card">
        <p class="eyebrow flag-label"><span class="flag flag-uae" aria-hidden="true"></span> Live UAE Time</p>
        <div class="clock-display">
          <time class="main-clock" id="uae-clock" datetime="">--:--:--</time>
          <div class="analog-clock" aria-label="Analog UAE clock">
            <span class="clock-mark mark-12">12</span>
            <span class="clock-mark mark-3">3</span>
            <span class="clock-mark mark-6">6</span>
            <span class="clock-mark mark-9">9</span>
            <i class="hand hour-hand" id="clock-hour"></i>
            <i class="hand minute-hand" id="clock-minute"></i>
            <i class="hand second-hand" id="clock-second"></i>
            <b></b>
          </div>
        </div>
        <div class="clock-date" id="uae-date">Loading Dubai time...</div>
        <div class="clock-meta">
          <span>GST · UTC+4</span>
          <span>Auto-updating every second</span>
          <span id="sun-note">Weather desk loading</span>
        </div>
      </div>
      <aside class="clock-side" aria-label="Global reference times">
        <div>
          <span>UTC</span>
          <strong id="utc-clock">--:--</strong>
        </div>
        <div>
          <span><span class="flag flag-india" aria-hidden="true"></span> India</span>
          <strong id="ist-clock">--:--</strong>
        </div>
        <div>
          <span><span class="flag flag-us" aria-hidden="true"></span> New York</span>
          <strong id="ny-clock">--:--</strong>
        </div>
      </aside>
      <div class="hero-weather-strip" aria-label="Quick emirates weather">
        {emirates.map((emirate) => (
          <article data-hero-city={emirate.name}>
            <span>{emirate.name}</span>
            <strong data-hero-temp>--°</strong>
            <small><b data-hero-rain>--%</b> rain</small>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section weather-desk" id="weather" aria-label="Seven emirates weather">
    <div class="weather-heading">
      <div>
        <p class="eyebrow">Seven Emirates Weather</p>
        <h1>Weather, rain chance and alerts across the UAE</h1>
      </div>
      <p>
        Live conditions are pulled in the browser for all seven emirates. Use this as a fast
        public dashboard before moving into the news.
      </p>
    </div>

    <div class="alert-panel" id="weather-alert">
      <span>Live Alert</span>
      <strong>Checking rain, wind and heat conditions...</strong>
    </div>

    <div class="weather-grid" data-weather-grid>
      {emirates.map((emirate) => (
        <article
          class="weather-card is-loading"
          data-city={emirate.name}
          data-label={emirate.label}
          data-lat={emirate.lat}
          data-lon={emirate.lon}
        >
          <div class="weather-top">
            <div>
              <span>{emirate.label}</span>
              <h2>{emirate.name}</h2>
            </div>
            <strong data-temp>--°</strong>
          </div>
          <p data-summary>Loading live conditions...</p>
          <div class="weather-metrics">
            <span><b data-rain>--%</b> rain</span>
            <span><b data-wind>--</b> wind</span>
            <span><b data-humidity>--%</b> humidity</span>
          </div>
          <small data-updated>Updating now</small>
        </article>
      ))}
    </div>
  </section>

  <section class="market-ticker" aria-label="Live markets ticker">
    <div class="market-label"><span></span>Markets</div>
    <div class="market-window">
      <div class="market-track">
        {[0, 1].map((loop) => (
          <div class="market-group" aria-hidden={loop === 1 ? "true" : undefined}>
            <span class="market-item"><strong>Gold</strong> <em>XAU/USD</em> <b data-market-symbol="GC=F">Live</b></span>
            <span class="market-item"><strong>Silver</strong> <em>XAG/USD</em> <b data-market-symbol="SI=F">Live</b></span>
            <span class="market-item"><strong>Oil</strong> <em>US WTI</em> <b data-market-symbol="CL=F">Live</b></span>
            <span class="market-item"><strong>USD/AED</strong> <em>Dirham</em> <b data-market-symbol="AED=X">3.6725</b></span>
            <span class="market-item"><strong>Bitcoin</strong> <em>BTC/USD</em> <b data-market-symbol="BTC-USD">Live</b></span>
            <span class="market-item"><strong>Nasdaq</strong> <em>Futures</em> <b data-market-symbol="NQ=F">Live</b></span>
            <span class="market-item"><strong>Updated</strong> <em data-market-updated>Checking feed</em></span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section news-entry" id="news" aria-label="Dubai news">
    <div class="news-heading">
      <p class="eyebrow">News Desk</p>
      <h2>After time and weather, read the stories shaping Dubai</h2>
    </div>
    <article class="lead">
      <a href={`/articles/${leadArticle.id}`}>
        <img src={leadArticle.data.image} alt={leadArticle.data.imageAlt} />
      </a>
      <div class="lead-copy">
        <p class="eyebrow">{leadArticle.data.category}</p>
        <h3>
          <a href={`/articles/${leadArticle.id}`}>{leadArticle.data.title}</a>
        </h3>
        <p>{leadArticle.data.description}</p>
        <div class="meta">
          <span>{leadArticle.data.author}</span>
          <span>{leadArticle.data.date.toLocaleDateString("en-US", {
            month: "long",
            day: "numeric",
            year: "numeric",
          })} · {leadArticle.data.publishedTime}</span>
          <span>{estimateRead(leadArticle)} min read</span>
        </div>
      </div>
    </article>
  </section>

  <section class="section live-briefing" aria-label="Live briefing">
    <aside class="brief-card">
      <p class="eyebrow">Quick Brief</p>
      {liveNews.map((article) => (
        <a href={`/articles/${article.id}`}>
          <span>{article.data.category}</span>
          <strong>{article.data.title}</strong>
        </a>
      ))}
    </aside>
    <div class="editor-grid">
      {editorPicks.map((article) => (
        <a class="editor-pick" href={`/articles/${article.id}`}>
          <img src={article.data.image} alt={article.data.imageAlt} loading="lazy" />
          <span>{article.data.category}</span>
          <strong>{article.data.title}</strong>
          <small>{estimateRead(article)} min read · {article.data.publishedTime}</small>
        </a>
      ))}
    </div>
  </section>

  <section class="section category-strip" aria-label="Sections">
    {categories.map((category) => (
      <a href={`/category/${category.toLowerCase().replaceAll(" ", "-")}`}>
        {category}
      </a>
    ))}
  </section>

  <section class="section news-grid">
    <div class="section-heading">
      <p class="eyebrow">Latest</p>
      <h2>More From Dubai Time</h2>
    </div>
    <div class="cards">
      {moreArticles.map((article) => (
        <article class="story-card">
          <a href={`/articles/${article.id}`}>
            <img src={article.data.image} alt={article.data.imageAlt} loading="lazy" />
          </a>
          <div>
            <p class="eyebrow">{article.data.category}</p>
            <h3><a href={`/articles/${article.id}`}>{article.data.title}</a></h3>
            <p>{article.data.description}</p>
          </div>
        </article>
      ))}
    </div>
  </section>

  <script define:vars={{ emirates }}>
    const conditionText = {
      0: "Clear sky",
      1: "Mainly clear",
      2: "Partly cloudy",
      3: "Overcast",
      45: "Fog",
      48: "Depositing rime fog",
      51: "Light drizzle",
      53: "Moderate drizzle",
      55: "Dense drizzle",
      61: "Slight rain",
      63: "Moderate rain",
      65: "Heavy rain",
      71: "Slight snow",
      80: "Light rain showers",
      81: "Rain showers",
      82: "Heavy rain showers",
      95: "Thunderstorm",
    };

    const formatTime = (timeZone, withSeconds = false) =>
      new Intl.DateTimeFormat("en-US", {
        timeZone,
        hour: "2-digit",
        minute: "2-digit",
        second: withSeconds ? "2-digit" : undefined,
        hour12: false,
      }).format(new Date());

    const updateClock = () => {
      const now = new Date();
      const uaeClock = document.getElementById("uae-clock");
      const uaeDate = document.getElementById("uae-date");
      const utcClock = document.getElementById("utc-clock");
      const istClock = document.getElementById("ist-clock");
      const nyClock = document.getElementById("ny-clock");
      const hourHand = document.getElementById("clock-hour");
      const minuteHand = document.getElementById("clock-minute");
      const secondHand = document.getElementById("clock-second");

      if (uaeClock) {
        uaeClock.textContent = formatTime("Asia/Dubai", true);
        uaeClock.setAttribute("datetime", now.toISOString());
      }
      if (hourHand && minuteHand && secondHand) {
        const parts = new Intl.DateTimeFormat("en-US", {
          timeZone: "Asia/Dubai",
          hour: "numeric",
          minute: "numeric",
          second: "numeric",
          hour12: false,
        }).formatToParts(now);
        const values = Object.fromEntries(parts.map((part) => [part.type, Number(part.value)]));
        const hour = values.hour % 12;
        const minute = values.minute || 0;
        const second = values.second || 0;
        hourHand.style.transform = `translateX(-50%) rotate(${hour * 30 + minute * 0.5}deg)`;
        minuteHand.style.transform = `translateX(-50%) rotate(${minute * 6 + second * 0.1}deg)`;
        secondHand.style.transform = `translateX(-50%) rotate(${second * 6}deg)`;
      }
      if (uaeDate) {
        uaeDate.textContent = new Intl.DateTimeFormat("en-US", {
          timeZone: "Asia/Dubai",
          weekday: "long",
          month: "long",
          day: "numeric",
          year: "numeric",
        }).format(now);
      }
      if (utcClock) utcClock.textContent = formatTime("UTC");
      if (istClock) istClock.textContent = formatTime("Asia/Kolkata");
      if (nyClock) nyClock.textContent = formatTime("America/New_York");
    };

    const buildWeatherUrl = () => {
      const latitudes = emirates.map((city) => city.lat).join(",");
      const longitudes = emirates.map((city) => city.lon).join(",");
      return `https://api.open-meteo.com/v1/forecast?latitude=${latitudes}&longitude=${longitudes}&current=temperature_2m,relative_humidity_2m,precipitation,rain,weather_code,wind_speed_10m&hourly=precipitation_probability&forecast_days=1&timezone=Asia%2FDubai`;
    };

    const setWeatherError = () => {
      document.querySelectorAll(".weather-card").forEach((card) => {
        card.classList.remove("is-loading");
        card.querySelector("[data-summary]").textContent = "Live weather is temporarily unavailable.";
        card.querySelector("[data-updated]").textContent = "Please refresh in a few minutes.";
      });
      const alert = document.getElementById("weather-alert");
      if (alert) {
        alert.className = "alert-panel alert-watch";
        alert.querySelector("strong").textContent = "Weather feed is not responding. Keep official local alerts in view.";
      }
    };

    const updateWeather = async () => {
      try {
        const response = await fetch(buildWeatherUrl());
        if (!response.ok) throw new Error("Weather request failed");
        const payload = await response.json();
        const cityWeather = Array.isArray(payload) ? payload : [payload];
        let highestRain = 0;
        let strongestWind = 0;
        let hottest = 0;

        cityWeather.forEach((item, index) => {
          const card = document.querySelector(`[data-city="${emirates[index].name}"]`);
          const heroCard = document.querySelector(`[data-hero-city="${emirates[index].name}"]`);
          if (!card || !item.current) return;

          const current = item.current;
          const rainChance = item.hourly?.precipitation_probability?.[0] ?? 0;
          highestRain = Math.max(highestRain, rainChance, current.rain || 0);
          strongestWind = Math.max(strongestWind, current.wind_speed_10m || 0);
          hottest = Math.max(hottest, current.temperature_2m || 0);

          card.classList.remove("is-loading");
          card.querySelector("[data-temp]").textContent = `${Math.round(current.temperature_2m)}°`;
          card.querySelector("[data-summary]").textContent = conditionText[current.weather_code] || "Current conditions";
          card.querySelector("[data-rain]").textContent = `${rainChance}%`;
          card.querySelector("[data-wind]").textContent = `${Math.round(current.wind_speed_10m)} km/h`;
          card.querySelector("[data-humidity]").textContent = `${Math.round(current.relative_humidity_2m)}%`;
          card.querySelector("[data-updated]").textContent = `Updated ${formatTime("Asia/Dubai")} GST`;
          if (heroCard) {
            heroCard.querySelector("[data-hero-temp]").textContent = `${Math.round(current.temperature_2m)}°`;
            heroCard.querySelector("[data-hero-rain]").textContent = `${rainChance}%`;
            heroCard.classList.toggle("has-rain", rainChance >= 30 || current.rain > 0);
          }

          card.classList.toggle("has-rain", rainChance >= 30 || current.rain > 0);
          card.classList.toggle("has-heat", current.temperature_2m >= 38);
        });

        const alert = document.getElementById("weather-alert");
        const sunNote = document.getElementById("sun-note");
        if (alert) {
          const message =
            highestRain >= 40
              ? "Rain watch active in parts of the UAE. Check roads, outdoor plans and official advisories."
              : strongestWind >= 35
                ? "Wind watch active. Outdoor visibility and exposed roads may need attention."
                : hottest >= 38
                  ? "Heat watch active. Hydration and midday outdoor exposure matter today."
                  : "No major rain or wind signal from the live weather feed right now.";
          alert.className = highestRain >= 40 || strongestWind >= 35 || hottest >= 38
            ? "alert-panel alert-watch"
            : "alert-panel alert-clear";
          alert.querySelector("strong").textContent = message;
        }
        if (sunNote) sunNote.textContent = `UAE weather refreshed ${formatTime("Asia/Dubai")} GST`;
      } catch {
        setWeatherError();
      }
    };

    const marketSymbols = ["GC=F", "SI=F", "CL=F", "AED=X", "BTC-USD", "NQ=F"];
    const formatMarketValue = (symbol, value) => {
      if (!Number.isFinite(value)) return "Live";
      if (symbol === "AED=X") return value.toFixed(4);
      if (symbol === "BTC-USD") return value.toLocaleString("en-US", { maximumFractionDigits: 0 });
      if (symbol === "GC=F" || symbol === "SI=F" || symbol === "CL=F") {
        return value.toLocaleString("en-US", { maximumFractionDigits: 2 });
      }
      return value.toLocaleString("en-US", { maximumFractionDigits: 1 });
    };

    const setMarketValue = (symbol, value) => {
      document.querySelectorAll(`[data-market-symbol="${symbol}"]`).forEach((item) => {
        item.textContent = formatMarketValue(symbol, value);
      });
    };

    const updateMarkets = async () => {
      try {
        const response = await fetch("/api/markets");
        if (!response.ok) throw new Error("Market request failed");
        const payload = await response.json();
        Object.entries(payload.markets || {}).forEach(([symbol, price]) => {
          setMarketValue(symbol, Number(price));
        });
        document.querySelectorAll("[data-market-updated]").forEach((item) => {
          item.textContent = `${formatTime("Asia/Dubai")} GST`;
        });
      } catch {
        setMarketValue("AED=X", 3.6725);
        document.querySelectorAll("[data-market-updated]").forEach((item) => {
          item.textContent = "Live feed retrying";
        });
      }
    };

    updateClock();
    updateWeather();
    updateMarkets();
    window.setInterval(updateClock, 1000);
    window.setInterval(updateWeather, 15 * 60 * 1000);
    window.setInterval(updateMarkets, 5 * 60 * 1000);
  </script>
</BaseLayout>

<style>
  .time-hero {
    background:
      linear-gradient(90deg, rgba(255, 255, 255, 0.08), transparent 32%, rgba(255, 255, 255, 0.06)),
      linear-gradient(135deg, #07131d 0%, #0d2d38 52%, #0b6e69 100%);
    color: #fffaf0;
  }

  .time-grid {
    align-items: stretch;
    display: grid;
    gap: 22px;
    grid-template-columns: minmax(0, 1fr) 310px;
    min-height: 460px;
    padding-bottom: 54px;
    padding-top: 54px;
  }

  .clock-card,
  .clock-side {
    backdrop-filter: blur(24px) saturate(1.18);
    background:
      linear-gradient(135deg, rgba(255, 255, 255, 0.16), rgba(255, 255, 255, 0.07)),
      linear-gradient(135deg, rgba(194, 145, 45, 0.08), rgba(11, 110, 105, 0.1));
    border: 1px solid rgba(255, 255, 255, 0.22);
    border-radius: 12px;
    box-shadow: 0 30px 80px rgba(0, 0, 0, 0.28);
  }

  .clock-card {
    container-type: inline-size;
    display: flex;
    flex-direction: column;
    justify-content: center;
    min-width: 0;
    overflow: hidden;
    padding: clamp(28px, 5vw, 58px);
  }

  .clock-card .eyebrow {
    color: #f4d99b;
  }

  .flag-label {
    align-items: center;
    display: flex;
    gap: 10px;
  }

  .flag {
    border-radius: 3px;
    box-shadow: 0 0 0 1px rgba(255, 255, 255, 0.35);
    display: inline-block;
    flex: 0 0 auto;
    height: 15px;
    overflow: hidden;
    position: relative;
    vertical-align: -2px;
    width: 24px;
  }

  .flag-uae {
    background:
      linear-gradient(90deg, #e31b23 0 25%, transparent 25%),
      linear-gradient(#009a44 0 33.33%, #fff 33.33% 66.66%, #000 66.66%);
  }

  .flag-india {
    background: linear-gradient(#ff9933 0 33.33%, #fff 33.33% 66.66%, #138808 66.66%);
  }

  .flag-india::after {
    background: #000080;
    border-radius: 50%;
    content: "";
    height: 5px;
    left: 50%;
    position: absolute;
    top: 50%;
    transform: translate(-50%, -50%);
    width: 5px;
  }

  .flag-us {
    background:
      linear-gradient(90deg, #3c3b6e 0 42%, transparent 42%),
      repeating-linear-gradient(#b22234 0 2px, #fff 2px 4px);
  }

  .clock-display {
    align-items: center;
    display: grid;
    gap: clamp(18px, 3vw, 34px);
    grid-template-columns: minmax(0, 1fr) clamp(130px, 13vw, 165px);
  }

  .main-clock {
    font-family: Georgia, "Times New Roman", serif;
    font-size: clamp(4rem, 7vw, 6.25rem);
    font-variant-numeric: tabular-nums;
    font-weight: 800;
    letter-spacing: 0.01em;
    line-height: 0.92;
    max-width: 100%;
    overflow-wrap: normal;
    white-space: nowrap;
  }

  .analog-clock {
    aspect-ratio: 1;
    background:
      radial-gradient(circle at 48% 40%, #ffffff 0 38%, #f5f7f8 68%, #eef4f7 100%);
    border: 1px solid rgba(255, 255, 255, 0.92);
    border-radius: 50%;
    box-shadow:
      inset 0 0 18px rgba(8, 76, 97, 0.04),
      0 18px 42px rgba(0, 0, 0, 0.22);
    min-width: 112px;
    position: relative;
    justify-self: end;
  }

  .analog-clock::before {
    border: 1px solid rgba(8, 76, 97, 0.06);
    border-radius: 50%;
    content: "";
    inset: 11px;
    position: absolute;
  }

  .clock-mark {
    color: rgba(23, 23, 23, 0.56);
    font-size: 1rem;
    font-weight: 900;
    position: absolute;
  }

  .mark-12 {
    left: 50%;
    top: 12px;
    transform: translateX(-50%);
  }

  .mark-3 {
    right: 14px;
    top: 50%;
    transform: translateY(-50%);
  }

  .mark-6 {
    bottom: 10px;
    left: 50%;
    transform: translateX(-50%);
  }

  .mark-9 {
    left: 14px;
    top: 50%;
    transform: translateY(-50%);
  }

  .hand {
    background: #25282c;
    border-radius: 999px;
    bottom: 50%;
    left: 50%;
    position: absolute;
    transform: translateX(-50%) rotate(0deg);
    transform-origin: center bottom;
  }

  .hour-hand {
    height: 28%;
    width: 6px;
  }

  .minute-hand {
    height: 36%;
    width: 4px;
  }

  .second-hand {
    background: #e23b44;
    height: 40%;
    width: 2px;
  }

  .analog-clock b {
    background: #e23b44;
    border: 3px solid #25282c;
    border-radius: 50%;
    height: 14px;
    left: 50%;
    position: absolute;
    top: 50%;
    transform: translate(-50%, -50%);
    width: 14px;
  }

  .hero-weather-strip {
    backdrop-filter: blur(22px) saturate(1.18);
    background:
      linear-gradient(135deg, rgba(255, 255, 255, 0.15), rgba(255, 255, 255, 0.06));
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 12px;
    box-shadow: 0 24px 60px rgba(0, 0, 0, 0.2);
    display: grid;
    gap: 10px;
    grid-column: 1 / -1;
    grid-template-columns: repeat(7, minmax(0, 1fr));
    padding: 12px;
  }

  .hero-weather-strip article {
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 9px;
    display: grid;
    gap: 4px;
    min-width: 0;
    padding: 12px;
  }

  .hero-weather-strip article.has-rain {
    border-color: rgba(244, 217, 155, 0.55);
  }

  .hero-weather-strip span {
    color: rgba(255, 250, 240, 0.78);
    font-size: 0.78rem;
    font-weight: 900;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .hero-weather-strip strong {
    color: #fffaf0;
    font-family: Georgia, "Times New Roman", serif;
    font-size: 1.75rem;
    line-height: 1;
  }

  .hero-weather-strip small {
    color: rgba(255, 250, 240, 0.68);
    font-size: 0.76rem;
    font-weight: 800;
  }


  .clock-date {
