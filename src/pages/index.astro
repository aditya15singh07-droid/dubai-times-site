---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { categories } from "../data/articles";

const articles = (await getCollection("articles", ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const [leadArticle, ...moreArticles] = articles;
const estimateRead = (article) => Math.max(3, Math.round((article.body || "").split(/\s+/).length / 220));
const latestDate = articles[0]?.data.date;
const todayCount = latestDate
  ? articles.filter((article) => article.data.date.toDateString() === latestDate.toDateString()).length
  : 0;
const activeSections = new Set(articles.map((article) => article.data.category)).size;
const editorPicks = categories
  .map((category) => articles.find((article) => article.data.category === category))
  .filter(Boolean)
  .slice(0, 4);
const mostRead = [
  articles.find((article) => article.id === "jebel-ali-port-dubai-trade-engine-2026"),
  articles.find((article) => article.id === "dubai-metro-blue-line-tunnelling-future-commutes-2026"),
  articles.find((article) => article.id === "dubai-property-sales-april-resilience-2026"),
  articles.find((article) => article.id === "icp-ai-ecosystem-implementation-2026"),
].filter(Boolean);
const deepReads = articles
  .filter((article) => estimateRead(article) >= 4)
  .slice(0, 3);
const updateStamp = latestDate?.toLocaleDateString("en-US", {
  month: "long",
  day: "numeric",
  year: "numeric",
});

const marqueeItems = [
  {
    name: "Dubai Investments",
    icon: "DXB",
    tagline: "Global capital inflows",
    stat: "AED48B Apr",
    href: "/articles/dubai-property-sales-april-resilience-2026",
  },
  {
    name: "Dubai South",
    icon: "DS",
    tagline: "Airport-city growth corridor",
    stat: "Top Area",
    href: "/articles/dubai-property-sales-april-resilience-2026",
  },
  {
    name: "Business Bay",
    icon: "BB",
    tagline: "Commercial and branded towers",
    stat: "Prime",
    href: "/category/real-estate",
  },
  {
    name: "Palm Jumeirah",
    icon: "PJ",
    tagline: "Waterfront luxury benchmark",
    stat: "Luxury",
    href: "/category/real-estate",
  },
  {
    name: "Commercial Spaces",
    icon: "CS",
    tagline: "Grade-A office momentum",
    stat: "+33.9%",
    href: "/articles/dubai-property-sales-april-resilience-2026",
  },
  {
    name: "Waterfront Apartments",
    icon: "WA",
    tagline: "Branded lifestyle assets",
    stat: "Dubai Marina",
    href: "/category/lifestyle",
  },
  {
    name: "Dubai Islands",
    icon: "DI",
    tagline: "New coastline investment story",
    stat: "Emerging",
    href: "/category/real-estate",
  },
  {
    name: "UAE Developers",
    icon: "UD",
    tagline: "Execution and trust signals",
    stat: "Watchlist",
    href: "/category/business",
  },
];

const marqueeLoop = [...marqueeItems, ...marqueeItems];

const liveNews = [
  {
    label: "Dubai",
    headline: "RTA says Al Khaleej Street tunnel has reached 80% completion.",
    href: "/articles/rta-al-khaleej-tunnel-shindagha-corridor-2026",
  },
  {
    label: "Business",
    headline: "DEWA's transmission projects under construction exceed AED8.5 billion.",
    href: "/articles/dewa-transmission-grid-expansion-2025-2028",
  },
  {
    label: "Culture",
    headline: "Dubai launches MODA, the region's first museum dedicated to digital art.",
    href: "/articles/dubai-museum-of-digital-art-difc-2026",
  },
  {
    label: "Markets",
    headline: "Dubai Holding becomes Emaar Properties' largest shareholder.",
    href: "/articles/dubai-holding-emaar-stake-market-signal-2026",
  },
];
---

<BaseLayout
  title="Dubai Times | Dubai News, Business, Real Estate And Lifestyle"
  description="Dubai Times is a new digital news publication covering Dubai, UAE business, real estate, travel, lifestyle, technology, and the region."
>
  <section class="section trust-strip" aria-label="Dubai Times edition details">
    <span>Dubai Edition</span>
    <span>Source-linked coverage</span>
    <span>Business, property, travel and culture</span>
    <span>Updated May 17, 2026</span>
  </section>

  <section class="section hero">
    <article class="lead">
      <a href={`/articles/${leadArticle.id}`}>
        <img src={leadArticle.data.image} alt={leadArticle.data.imageAlt} />
      </a>
      <div class="lead-copy">
        <p class="eyebrow">{leadArticle.data.category}</p>
        <h1>
          <a href={`/articles/${leadArticle.id}`}>{leadArticle.data.title}</a>
        </h1>
        <p>{leadArticle.data.description}</p>
        <div class="meta">
          <span>{leadArticle.data.author}</span>
          <span>{leadArticle.data.date.toLocaleDateString("en-US", {
            month: "long",
            day: "numeric",
            year: "numeric",
          })} · {leadArticle.data.publishedTime}</span>
        </div>
      </div>
    </article>
  </section>

  <section class="section intelligence-band" aria-label="Real estate market intelligence">
    <div class="marquee-panel">
      <div class="marquee-copy">
        <p class="eyebrow">Market Intelligence</p>
        <h2>Premium property signals investors are watching</h2>
      </div>
      <div class="marquee-shell">
        <div class="marquee-track">
          {marqueeLoop.map((item) => (
            <a class="market-card" href={item.href} aria-label={`${item.name}: ${item.tagline}`}>
              <span class="market-icon">{item.icon}</span>
              <span class="market-text">
                <strong>{item.name}</strong>
                <small>{item.tagline}</small>
              </span>
              <span class="market-stat">{item.stat}</span>
            </a>
          ))}
        </div>
      </div>
    </div>

    <aside class="live-brief" aria-label="Live news brief">
      <div class="live-heading">
        <span></span>
        <p>Live Brief</p>
      </div>
      <div class="live-list">
        {liveNews.map((item) => (
          <a href={item.href}>
            <span>{item.label}</span>
            <strong>{item.headline}</strong>
          </a>
        ))}
      </div>
    </aside>
  </section>

  <section class="section category-strip" aria-label="Sections">
    {categories.map((category) => (
      <a href={`/category/${category.toLowerCase().replaceAll(" ", "-")}`}>
        {category}
      </a>
    ))}
  </section>

  <section class="section engagement-hub" aria-label="Dubai Times reader dashboard">
    <div class="hub-main">
      <div class="hub-heading">
        <p class="eyebrow">Reader Desk</p>
        <h2>Start with the stories that explain the day</h2>
        <p>
          A cleaner way to enter the edition: the latest city signals, sharp business context,
          and deeper reads worth staying with.
        </p>
      </div>
      <div class="hub-stats" aria-label="Edition stats">
        <span><strong>{todayCount}</strong> new today</span>
        <span><strong>{articles.length}</strong> total reads</span>
        <span><strong>{activeSections}</strong> active desks</span>
        <span><strong>{updateStamp}</strong> latest file</span>
      </div>
      <div class="editor-grid">
        {editorPicks.map((article) => (
          <a class="editor-pick" href={`/articles/${article.id}`}>
            <img src={article.data.image} alt={article.data.imageAlt} loading="lazy" />
            <span>{article.data.category}</span>
            <strong>{article.data.title}</strong>
            <small>{estimateRead(article)} min read · {article.data.publishedTime}</small>
          </a>
        ))}
      </div>
    </div>

    <aside class="reader-stack" aria-label="Most read and reader pulse">
      <div class="stack-card most-read">
        <p class="eyebrow">Most Read</p>
        {mostRead.map((article, index) => (
          <a href={`/articles/${article.id}`}>
            <span>{String(index + 1).padStart(2, "0")}</span>
            <strong>{article.data.title}</strong>
          </a>
        ))}
      </div>
      <div class="stack-card reader-pulse" data-reader-pulse>
        <p class="eyebrow">Reader Pulse</p>
        <h3>What should Dubai Times explain deeper next?</h3>
        <button type="button" data-vote="property">Property prices</button>
        <button type="button" data-vote="ai">AI in government</button>
        <p class="pulse-result" data-pulse-result>Vote to see the newsroom pulse.</p>
      </div>
    </aside>
  </section>

  <section class="section deep-read-band" aria-label="Deep reads">
    <div>
      <p class="eyebrow">Stay Longer</p>
      <h2>Deep reads for people who want the full picture</h2>
    </div>
    <div class="deep-read-list">
      {deepReads.map((article) => (
        <a href={`/articles/${article.id}`}>
          <span>{article.data.category}</span>
          <strong>{article.data.title}</strong>
          <small>{estimateRead(article)} min read</small>
        </a>
      ))}
    </div>
  </section>

  <section class="section news-grid">
    <div class="section-heading">
      <p class="eyebrow">Latest</p>
      <h2>Today On Dubai Times</h2>
    </div>
    <div class="cards">
      {moreArticles.map((article) => (
        <article class="story-card">
          <a href={`/articles/${article.id}`}>
            <img src={article.data.image} alt={article.data.imageAlt} loading="lazy" />
          </a>
          <div>
            <p class="eyebrow">{article.data.category}</p>
            <h3><a href={`/articles/${article.id}`}>{article.data.title}</a></h3>
            <p>{article.data.description}</p>
          </div>
        </article>
      ))}
    </div>
  </section>

  <script>
    const pulse = document.querySelector("[data-reader-pulse]");
    const result = document.querySelector("[data-pulse-result]");
    const voteLabels = {
      property: "Property prices is leading this session.",
      ai: "AI in government is leading this session.",
    };

    const setPulse = (vote) => {
      if (!result || !voteLabels[vote]) return;
      result.textContent = voteLabels[vote];
      window.localStorage.setItem("dubai-times-pulse", vote);
      pulse?.querySelectorAll("button").forEach((button) => {
        button.toggleAttribute("aria-pressed", button.getAttribute("data-vote") === vote);
      });
    };

    const savedPulse = window.localStorage.getItem("dubai-times-pulse");
    if (savedPulse) setPulse(savedPulse);

    pulse?.querySelectorAll("button").forEach((button) => {
      button.addEventListener("click", () => setPulse(button.getAttribute("data-vote")));
    });
  </script>
</BaseLayout>

<style>
  .hero {
    padding-top: 22px;
  }

  .trust-strip {
    color: var(--accent-strong);
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    padding-bottom: 0;
    padding-top: 18px;
  }

  .trust-strip span {
    background: rgba(255, 255, 255, 0.84);
    border: 1px solid var(--line);
    border-radius: 999px;
    font-size: 0.78rem;
    font-weight: 800;
    padding: 8px 11px;
  }

  .intelligence-band {
    align-items: start;
    display: grid;
    gap: 20px;
    grid-template-columns: minmax(0, 1fr) 330px;
    padding-bottom: 18px;
    padding-top: 14px;
  }

  .marquee-panel,
  .live-brief {
    background:
      linear-gradient(135deg, rgba(255, 255, 255, 0.84), rgba(255, 255, 255, 0.54)),
      radial-gradient(circle at top left, rgba(194, 145, 45, 0.18), transparent 34%),
      radial-gradient(circle at bottom right, rgba(11, 110, 105, 0.14), transparent 34%);
    border: 1px solid rgba(222, 216, 205, 0.84);
    border-radius: 8px;
    box-shadow: 0 20px 50px rgba(31, 39, 44, 0.08);
    overflow: hidden;
  }

  .marquee-panel {
    min-width: 0;
    padding: 22px 0 20px;
    position: relative;
  }

  .marquee-panel::before {
    background: linear-gradient(90deg, var(--gold), rgba(11, 110, 105, 0.45), transparent);
    content: "";
    height: 1px;
    inset: 0 0 auto;
    position: absolute;
  }

  .marquee-copy {
    align-items: end;
    display: flex;
    gap: 18px;
    justify-content: space-between;
    padding: 0 22px 18px;
  }

  .marquee-copy h2 {
    font-family: Georgia, "Times New Roman", serif;
    font-size: clamp(1.45rem, 3vw, 2.5rem);
    line-height: 1;
    margin: 0;
    max-width: 620px;
    text-align: right;
  }

  .marquee-shell {
    mask-image: linear-gradient(90deg, transparent, #000 9%, #000 91%, transparent);
    overflow: hidden;
    position: relative;
  }

  .marquee-track {
    animation: market-scroll 38s linear infinite;
    display: flex;
    gap: 14px;
    width: max-content;
    will-change: transform;
  }

  .marquee-shell:hover .marquee-track {
    animation-play-state: paused;
  }

  .market-card {
    align-items: center;
    backdrop-filter: blur(18px);
    background:
      linear-gradient(135deg, rgba(255, 255, 255, 0.78), rgba(255, 255, 255, 0.42)),
      linear-gradient(135deg, rgba(194, 145, 45, 0.12), rgba(8, 76, 97, 0.08));
    border: 1px solid rgba(255, 255, 255, 0.76);
    border-radius: 8px;
    box-shadow: 0 14px 34px rgba(8, 76, 97, 0.09);
    display: grid;
    gap: 12px;
    grid-template-columns: 44px 190px auto;
    min-height: 82px;
    padding: 14px;
    position: relative;
    transition:
      transform 180ms ease,
      border-color 180ms ease,
      box-shadow 180ms ease;
    width: 360px;
  }

  .market-card::after {
    background: linear-gradient(135deg, rgba(194, 145, 45, 0.58), rgba(11, 110, 105, 0.32), transparent);
    border-radius: inherit;
    content: "";
    inset: -1px;
    opacity: 0;
    pointer-events: none;
    position: absolute;
    transition: opacity 180ms ease;
    z-index: -1;
  }

  .market-card:hover {
    border-color: rgba(194, 145, 45, 0.62);
    box-shadow: 0 18px 42px rgba(8, 76, 97, 0.15);
    transform: translateY(-3px);
  }

  .market-card:hover::after {
    opacity: 1;
  }

  .market-icon {
    align-items: center;
    background: linear-gradient(135deg, var(--accent-strong), var(--accent));
    border-radius: 50%;
    color: #fff;
    display: flex;
    font-size: 0.72rem;
    font-weight: 900;
    height: 44px;
    justify-content: center;
    letter-spacing: 0.04em;
    width: 44px;
  }

  .market-text {
    display: grid;
    gap: 5px;
    min-width: 0;
  }

  .market-text strong {
    font-family: Georgia, "Times New Roman", serif;
    font-size: 1.08rem;
    line-height: 1.05;
  }

  .market-text small {
    color: var(--muted);
    font-size: 0.82rem;
    font-weight: 700;
    line-height: 1.25;
  }

  .market-stat {
    border: 1px solid rgba(194, 145, 45, 0.32);
    border-radius: 999px;
    color: var(--accent-strong);
    font-size: 0.78rem;
    font-weight: 900;
    justify-self: end;
    padding: 7px 9px;
    white-space: nowrap;
  }

  .live-brief {
    padding: 18px;
  }

  .live-heading {
    align-items: center;
    display: flex;
    gap: 9px;
    margin-bottom: 10px;
  }

  .live-heading span {
    animation: live-pulse 1.8s ease-in-out infinite;
    background: #d72828;
    border-radius: 50%;
    box-shadow: 0 0 0 6px rgba(215, 40, 40, 0.12);
    height: 8px;
    width: 8px;
  }

  .live-heading p {
    color: var(--accent-strong);
    font-size: 0.78rem;
    font-weight: 900;
    letter-spacing: 0.1em;
    margin: 0;
    text-transform: uppercase;
  }

  .live-list {
    display: grid;
    gap: 9px;
  }

  .live-list a {
    border-top: 1px solid rgba(222, 216, 205, 0.8);
    display: grid;
    gap: 4px;
    padding-top: 9px;
  }

  .live-list span {
    color: var(--gold);
    font-size: 0.72rem;
    font-weight: 900;
    text-transform: uppercase;
  }

  .live-list strong {
    font-size: 0.9rem;
    line-height: 1.32;
  }

  .live-list a:hover strong {
    color: var(--accent-strong);
  }

  @keyframes market-scroll {
    from {
      transform: translate3d(0, 0, 0);
    }

    to {
      transform: translate3d(calc(-50% - 7px), 0, 0);
    }
  }

  @keyframes live-pulse {
    0%,
    100% {
      transform: scale(1);
    }

    50% {
      transform: scale(1.35);
    }
  }

  @media (prefers-color-scheme: dark) {
    .marquee-panel,
    .live-brief {
      background:
        linear-gradient(135deg, rgba(17, 24, 30, 0.88), rgba(17, 24, 30, 0.62)),
        radial-gradient(circle at top left, rgba(194, 145, 45, 0.2), transparent 36%),
        radial-gradient(circle at bottom right, rgba(11, 110, 105, 0.22), transparent 36%);
      border-color: rgba(255, 255, 255, 0.12);
      box-shadow: 0 20px 50px rgba(0, 0, 0, 0.32);
    }

    .market-card {
      background:
        linear-gradient(135deg, rgba(255, 255, 255, 0.12), rgba(255, 255, 255, 0.05)),
        linear-gradient(135deg, rgba(194, 145, 45, 0.13), rgba(8, 76, 97, 0.16));
      border-color: rgba(255, 255, 255, 0.14);
    }

    .market-text strong,
    .live-list strong,
    .marquee-copy h2 {
      color: #f7f2e8;
    }
  }

  .lead {
    background:
      linear-gradient(135deg, rgba(255, 255, 255, 0.95), rgba(249, 247, 240, 0.9)),
      radial-gradient(circle at top right, rgba(194, 145, 45, 0.18), transparent 35%);
    border: 1px solid rgba(222, 216, 205, 0.84);
    border-radius: 8px;
    box-shadow: 0 24px 70px rgba(7, 19, 24, 0.18);
    display: grid;
    gap: 34px;
    grid-template-columns: minmax(0, 1.1fr) minmax(360px, 0.9fr);
    overflow: hidden;
  }

  .lead img {
    aspect-ratio: 16 / 10;
    height: 100%;
    object-fit: cover;
  }

  .lead-copy {
    align-self: center;
    padding: 26px 30px 26px 0;
  }

  h1 {
    font-family: Georgia, "Times New Roman", serif;
    font-size: clamp(2.3rem, 4.8vw, 4.2rem);
    line-height: 1;
    margin: 12px 0 18px;
    overflow-wrap: anywhere;
  }

  .lead-copy > p:not(.eyebrow) {
    color: var(--muted);
    font-size: 1.1rem;
    line-height: 1.7;
  }

  .meta {
    color: var(--muted);
    display: flex;
    flex-wrap: wrap;
    font-size: 0.9rem;
    gap: 12px;
    margin-top: 24px;
  }

  .category-strip {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    padding-bottom: 10px;
    padding-top: 10px;
  }

  .category-strip a {
    background: rgba(255, 255, 255, 0.84);
    border: 1px solid var(--line);
    border-radius: 4px;
    color: var(--accent-strong);
    font-weight: 800;
    padding: 10px 14px;
  }

  .section-heading {
    align-items: end;
    display: flex;
    justify-content: space-between;
    margin-bottom: 18px;
  }

  .section-heading h2 {
    font-family: Georgia, "Times New Roman", serif;
    font-size: clamp(2rem, 4vw, 3.4rem);
    margin: 0;
  }

  .engagement-hub {
    align-items: stretch;
    display: grid;
    gap: 22px;
    grid-template-columns: minmax(0, 1fr) 340px;
    padding-bottom: 18px;
    padding-top: 22px;
  }

  .hub-main,
  .stack-card,
  .deep-read-band {
    background:
      linear-gradient(135deg, rgba(255, 255, 255, 0.96), rgba(248, 245, 238, 0.92)),
      radial-gradient(circle at top right, rgba(194, 145, 45, 0.13), transparent 38%);
    border: 1px solid var(--line);
    border-radius: 8px;
    box-shadow: 0 18px 48px rgba(7, 19, 24, 0.08);
  }

  .hub-main {
    padding: 24px;
  }

  .hub-heading {
    align-items: end;
    display: grid;
    gap: 14px;
    grid-template-columns: minmax(0, 1fr) minmax(240px, 0.55fr);
  }

  .hub-heading h2,
  .deep-read-band h2 {
    font-family: Georgia, "Times New Roman", serif;
    font-size: clamp(1.9rem, 4vw, 3.1rem);
    line-height: 1;
    margin: 6px 0 0;
  }

  .hub-heading p:not(.eyebrow) {
    color: var(--muted);
    line-height: 1.6;
    margin: 0;
  }

  .hub-stats {
    border-bottom: 1px solid var(--line);
    border-top: 1px solid var(--line);
    display: grid;
    gap: 1px;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    margin: 22px 0;
  }

  .hub-stats span {
    background: rgba(255, 255, 255, 0.62);
    color: var(--muted);
    display: grid;
    font-size: 0.78rem;
    font-weight: 800;
    gap: 3px;
    padding: 14px;
    text-transform: uppercase;
  }

  .hub-stats strong {
    color: var(--accent-strong);
    font-family: Georgia, "Times New Roman", serif;
    font-size: 1.4rem;
    line-height: 1;
    text-transform: none;
  }

  .editor-grid {
    display: grid;
    gap: 16px;
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  .editor-pick {
    background: #fff;
    border: 1px solid rgba(222, 216, 205, 0.85);
    border-radius: 6px;
    display: grid;
    overflow: hidden;
    transition:
      transform 180ms ease,
      box-shadow 180ms ease;
  }

  .editor-pick:hover {
    box-shadow: 0 16px 34px rgba(7, 19, 24, 0.11);
    transform: translateY(-3px);
  }

  .editor-pick img {
    aspect-ratio: 16 / 10;
    object-fit: cover;
  }

  .editor-pick span,
  .editor-pick strong,
  .editor-pick small {
    margin-inline: 14px;
  }

  .editor-pick span {
    color: var(--accent);
    font-size: 0.72rem;
    font-weight: 900;
    letter-spacing: 0.08em;
    margin-top: 12px;
    text-transform: uppercase;
  }

  .editor-pick strong {
    font-family: Georgia, "Times New Roman", serif;
    font-size: 1.05rem;
    line-height: 1.14;
    margin-top: 6px;
  }

  .editor-pick small {
    color: var(--muted);
    font-size: 0.78rem;
    font-weight: 700;
    margin-bottom: 14px;
    margin-top: 10px;
  }

  .reader-stack {
    display: grid;
    gap: 18px;
  }

  .stack-card {
    padding: 20px;
  }

  .most-read {
    display: grid;
    gap: 13px;
