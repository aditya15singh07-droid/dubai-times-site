---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { categories } from "../data/articles";

const articleTimestamp = (article) => {
  const [hour = "00", minute = "00"] = String(article.data.publishedTime || "").match(/\d{2}/g) || [];
  const date = new Date(article.data.date);
  date.setHours(Number(hour), Number(minute), 0, 0);
  return date.getTime();
};

const articles = (await getCollection("articles", ({ data }) => !data.draft))
  .sort((a, b) => articleTimestamp(b) - articleTimestamp(a));

const [leadArticle, ...restArticles] = articles;
const topStories = restArticles.slice(0, 4);
const justIn = articles.slice(0, 7);
const latest = restArticles.slice(4, 16);
const opinionRail = articles.filter((article) => ["Business", "Technology", "Real Estate"].includes(article.data.category)).slice(0, 5);
const categoryBlocks = categories
  .map((category) => ({
    category,
    articles: articles.filter((article) => article.data.category === category).slice(0, 3),
  }))
  .filter((block) => block.articles.length);

const estimateRead = (article) => Math.max(3, Math.round((article.body || "").split(/\s+/).length / 220));

const emirates = [
  { name: "Abu Dhabi", label: "Capital", lat: 24.4539, lon: 54.3773 },
  { name: "Dubai", label: "Business hub", lat: 25.2048, lon: 55.2708 },
  { name: "Sharjah", label: "Culture", lat: 25.3463, lon: 55.4209 },
  { name: "Ajman", label: "Coast", lat: 25.4052, lon: 55.5136 },
  { name: "Fujairah", label: "East coast", lat: 25.1288, lon: 56.3265 },
  { name: "Ras Al Khaimah", label: "Northern emirate", lat: 25.8007, lon: 55.9762 },
  { name: "Umm Al Quwain", label: "Lagoon", lat: 25.5647, lon: 55.5552 },
];
---

<BaseLayout
  title="Dubai Time | UAE Business, Markets, Weather And Leadership News"
  description="Dubai Time is a UAE-first business and city news publication with live time, markets, weather and sharp context on Dubai."
>
  <section class="market-ticker" aria-label="Live markets ticker">
    <div class="market-label"><span></span>Markets</div>
    <div class="market-window">
      <div class="market-track">
        {[0, 1].map((loop) => (
          <div class="market-group" aria-hidden={loop === 1 ? "true" : undefined}>
            <span class="market-item"><strong>Gold</strong> <em>XAU/USD</em> <b data-market-symbol="GC=F">Live</b></span>
            <span class="market-item"><strong>Silver</strong> <em>XAG/USD</em> <b data-market-symbol="SI=F">Live</b></span>
            <span class="market-item"><strong>Oil</strong> <em>US WTI</em> <b data-market-symbol="CL=F">Live</b></span>
            <span class="market-item"><strong>USD/AED</strong> <em>Dirham</em> <b data-market-symbol="AED=X">3.6725</b></span>
            <span class="market-item"><strong>Bitcoin</strong> <em>BTC/USD</em> <b data-market-symbol="BTC-USD">Live</b></span>
            <span class="market-item"><strong>Nasdaq</strong> <em>Futures</em> <b data-market-symbol="NQ=F">Live</b></span>
            <span class="market-item"><strong>Updated</strong> <em data-market-updated>Checking feed</em></span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section masthead">
    <div>
      <p class="eyebrow">UAE Business Daily</p>
      <h1>Dubai stories for people building, investing and living in the city.</h1>
    </div>
    <p>
      A sharper front page for Dubai Time: live time, markets and weather up top,
      then the news desk below with business, property, technology and city coverage.
    </p>
  </section>

  <section class="section homepage-grid" id="news">
    <article class="lead-story">
      <a href={`/articles/${leadArticle.id}`} aria-label={leadArticle.data.title}>
        <img src={leadArticle.data.image} alt={leadArticle.data.imageAlt} />
      </a>
      <div>
        <p class="eyebrow">{leadArticle.data.category}</p>
        <h2><a href={`/articles/${leadArticle.id}`}>{leadArticle.data.title}</a></h2>
        <p>{leadArticle.data.description}</p>
        <div class="story-meta">
          <span>{leadArticle.data.author}</span>
          <span>{leadArticle.data.publishedTime}</span>
          <span>{estimateRead(leadArticle)} min read</span>
        </div>
      </div>
    </article>

    <aside class="top-stack" aria-label="Top stories">
      <div class="rail-heading">
        <p class="eyebrow">Top Stories</p>
        <strong>What matters now</strong>
      </div>
      {topStories.map((article, index) => (
        <a href={`/articles/${article.id}`} class="top-link">
          <span>{String(index + 1).padStart(2, "0")}</span>
          <div>
            <small>{article.data.category} · {article.data.publishedTime}</small>
            <strong>{article.data.title}</strong>
          </div>
        </a>
      ))}
    </aside>

    <aside class="live-panel" id="weather" aria-label="Live UAE dashboard">
      <div class="time-card">
        <span class="flag flag-uae" aria-hidden="true"></span>
        <p>Live UAE Time</p>
        <time id="uae-clock" datetime="">--:--:--</time>
        <small id="uae-date">Loading Dubai time...</small>
      </div>
      <div class="weather-mini">
        <div>
          <p class="eyebrow">Seven Emirates</p>
          <strong id="weather-alert">Weather feed loading</strong>
        </div>
        <div class="weather-pills">
          {emirates.map((emirate) => (
            <article data-city={emirate.name} data-lat={emirate.lat} data-lon={emirate.lon}>
              <span>{emirate.name}</span>
              <strong data-temp>--°</strong>
              <small><b data-rain>--%</b> rain</small>
            </article>
          ))}
        </div>
      </div>
      <div class="world-times">
        <span>UTC <b id="utc-clock">--:--</b></span>
        <span><span class="flag flag-india" aria-hidden="true"></span> India <b id="ist-clock">--:--</b></span>
        <span><span class="flag flag-us" aria-hidden="true"></span> New York <b id="ny-clock">--:--</b></span>
      </div>
    </aside>
  </section>

  <section class="section quick-grid" aria-label="Just in">
    <div class="section-title">
      <p class="eyebrow">Just In</p>
      <h2>Latest from the desk</h2>
    </div>
    <div class="just-in-grid">
      {justIn.map((article) => (
        <a href={`/articles/${article.id}`}>
          <span>{article.data.category}</span>
          <strong>{article.data.title}</strong>
          <small>{article.data.publishedTime} · {estimateRead(article)} min read</small>
        </a>
      ))}
    </div>
  </section>

  <section class="section split-section">
    <div class="latest-column">
      <div class="section-title">
        <p class="eyebrow">Latest News Feed</p>
        <h2>Business, city and leadership updates</h2>
      </div>
      <div class="latest-list">
        {latest.map((article) => (
          <article class="story-row">
            <a href={`/articles/${article.id}`}>
              <img src={article.data.image} alt={article.data.imageAlt} loading="lazy" />
            </a>
            <div>
              <p class="eyebrow">{article.data.category}</p>
              <h3><a href={`/articles/${article.id}`}>{article.data.title}</a></h3>
              <p>{article.data.description}</p>
              <small>{article.data.publishedTime} · {estimateRead(article)} min read</small>
            </div>
          </article>
        ))}
      </div>
    </div>

    <aside class="insight-rail">
      <p class="eyebrow">Founder Lens</p>
      <h2>Reads for operators and investors</h2>
      {opinionRail.map((article) => (
        <a href={`/articles/${article.id}`}>
          <span>{article.data.category}</span>
          <strong>{article.data.title}</strong>
        </a>
      ))}
    </aside>
  </section>

  <section class="section category-board" aria-label="Dubai Time sections">
    <div class="section-title">
      <p class="eyebrow">Sections</p>
      <h2>Browse Dubai Time by desk</h2>
    </div>
    <div class="category-grid">
      {categoryBlocks.map((block) => (
        <section>
          <a class="category-name" href={`/category/${block.category.toLowerCase().replaceAll(" ", "-")}`}>{block.category}</a>
          {block.articles.map((article) => (
            <a class="mini-card" href={`/articles/${article.id}`}>
              <img src={article.data.image} alt={article.data.imageAlt} loading="lazy" />
              <strong>{article.data.title}</strong>
              <small>{article.data.publishedTime}</small>
            </a>
          ))}
        </section>
      ))}
    </div>
  </section>

  <script define:vars={{ emirates }}>
    const conditionText = {
      0: "Clear",
      1: "Mainly clear",
      2: "Partly cloudy",
      3: "Overcast",
      45: "Fog",
      51: "Light drizzle",
      61: "Slight rain",
      63: "Moderate rain",
      65: "Heavy rain",
      80: "Light showers",
      95: "Thunderstorm",
    };

    const formatTime = (timeZone, withSeconds = false) =>
      new Intl.DateTimeFormat("en-US", {
        timeZone,
        hour: "2-digit",
        minute: "2-digit",
        second: withSeconds ? "2-digit" : undefined,
        hour12: false,
      }).format(new Date());

    const updateClock = () => {
      const now = new Date();
      const uaeClock = document.getElementById("uae-clock");
      const uaeDate = document.getElementById("uae-date");
      if (uaeClock) {
        uaeClock.textContent = formatTime("Asia/Dubai", true);
        uaeClock.setAttribute("datetime", now.toISOString());
      }
      if (uaeDate) {
        uaeDate.textContent = new Intl.DateTimeFormat("en-US", {
          timeZone: "Asia/Dubai",
          weekday: "long",
          month: "long",
          day: "numeric",
          year: "numeric",
        }).format(now);
      }
      const utcClock = document.getElementById("utc-clock");
      const istClock = document.getElementById("ist-clock");
      const nyClock = document.getElementById("ny-clock");
      if (utcClock) utcClock.textContent = formatTime("UTC");
      if (istClock) istClock.textContent = formatTime("Asia/Kolkata");
      if (nyClock) nyClock.textContent = formatTime("America/New_York");
    };

    const buildWeatherUrl = () => {
      const latitudes = emirates.map((city) => city.lat).join(",");
      const longitudes = emirates.map((city) => city.lon).join(",");
      return `https://api.open-meteo.com/v1/forecast?latitude=${latitudes}&longitude=${longitudes}&current=temperature_2m,relative_humidity_2m,rain,weather_code,wind_speed_10m&hourly=precipitation_probability&forecast_days=1&timezone=Asia%2FDubai`;
    };

    const updateWeather = async () => {
      const alert = document.getElementById("weather-alert");
      try {
        const response = await fetch(buildWeatherUrl());
        if (!response.ok) throw new Error("Weather request failed");
        const payload = await response.json();
        const cityWeather = Array.isArray(payload) ? payload : [payload];
        let hottest = 0;
        let highestRain = 0;
        cityWeather.forEach((item, index) => {
          const card = document.querySelector(`[data-city="${emirates[index].name}"]`);
          if (!card || !item.current) return;
          const current = item.current;
          const rainChance = item.hourly?.precipitation_probability?.[0] ?? 0;
          hottest = Math.max(hottest, current.temperature_2m || 0);
          highestRain = Math.max(highestRain, rainChance, current.rain || 0);
          card.querySelector("[data-temp]").textContent = `${Math.round(current.temperature_2m)}°`;
          card.querySelector("[data-rain]").textContent = `${rainChance}%`;
          card.title = conditionText[current.weather_code] || "Current weather";
        });
        if (alert) {
          alert.textContent =
            highestRain >= 30
              ? "Rain watch active in parts of the UAE"
              : hottest >= 38
                ? "Heat watch active across the Emirates"
                : "No major rain signal right now";
        }
      } catch {
        if (alert) alert.textContent = "Weather feed retrying";
      }
    };

    const marketSymbols = ["GC=F", "SI=F", "CL=F", "AED=X", "BTC-USD", "NQ=F"];
    const formatMarketValue = (symbol, value) => {
      if (!Number.isFinite(value)) return "Live";
      if (symbol === "AED=X") return value.toFixed(4);
      if (symbol === "BTC-USD") return value.toLocaleString("en-US", { maximumFractionDigits: 0 });
      if (symbol === "GC=F" || symbol === "SI=F" || symbol === "CL=F") {
        return value.toLocaleString("en-US", { maximumFractionDigits: 2 });
      }
      return value.toLocaleString("en-US", { maximumFractionDigits: 1 });
    };
    const setMarketValue = (symbol, value) => {
      document.querySelectorAll(`[data-market-symbol="${symbol}"]`).forEach((item) => {
        item.textContent = formatMarketValue(symbol, value);
      });
    };
    const updateMarkets = async () => {
      try {
        const response = await fetch("/api/markets");
        if (!response.ok) throw new Error("Market request failed");
        const payload = await response.json();
        Object.entries(payload.markets || {}).forEach(([symbol, price]) => setMarketValue(symbol, Number(price)));
        document.querySelectorAll("[data-market-updated]").forEach((item) => {
          item.textContent = `${formatTime("Asia/Dubai")} GST`;
        });
      } catch {
        setMarketValue("AED=X", 3.6725);
        document.querySelectorAll("[data-market-updated]").forEach((item) => {
          item.textContent = "Feed retrying";
        });
      }
    };

    updateClock();
    updateWeather();
    updateMarkets();
    window.setInterval(updateClock, 1000);
    window.setInterval(updateWeather, 15 * 60 * 1000);
    window.setInterval(updateMarkets, 5 * 60 * 1000);
  </script>
</BaseLayout>

<style>
  .market-ticker {
    align-items: stretch;
    background: #111214;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    color: #fff;
    display: flex;
    overflow: hidden;
  }

  .market-label {
    align-items: center;
    background: var(--accent);
    color: #fff;
    display: flex;
    flex: 0 0 auto;
    font-size: 0.82rem;
    font-weight: 950;
    gap: 8px;
    letter-spacing: 0.06em;
    padding: 13px max(18px, calc((100vw - 1180px) / 2 + 20px)) 13px 24px;
    text-transform: uppercase;
  }

  .market-label span {
    background: #111214;
    border-radius: 50%;
    height: 8px;
    width: 8px;
  }

  .market-window {
    flex: 1;
    min-width: 0;
    overflow: hidden;
  }

  .market-track {
    display: flex;
    width: max-content;
    animation: ticker 34s linear infinite;
  }

  .market-window:hover .market-track {
    animation-play-state: paused;
  }

  .market-group {
    align-items: center;
    display: flex;
    gap: 34px;
    padding: 0 34px;
  }

  .market-item {
    align-items: center;
    display: flex;
    gap: 8px;
    min-height: 43px;
    white-space: nowrap;
  }

  .market-item strong {
    color: #fff;
    font-size: 0.86rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .market-item em,
  .market-item b {
    color: rgba(255, 255, 255, 0.62);
    font-style: normal;
    font-weight: 800;
  }

  @keyframes ticker {
    to {
      transform: translateX(-50%);
    }
  }

  .masthead {
    align-items: end;
    border-bottom: 1px solid var(--line);
    display: grid;
    gap: 24px;
    grid-template-columns: minmax(0, 0.72fr) minmax(260px, 0.28fr);
    padding-bottom: 26px;
    padding-top: 34px;
  }

  .masthead h1 {
    font-family: Georgia, "Times New Roman", serif;
    font-size: clamp(2.35rem, 5vw, 4.9rem);
    letter-spacing: -0.02em;
    line-height: 0.9;
    margin: 10px 0 0;
    max-width: 930px;
  }

  .masthead p:not(.eyebrow) {
    color: var(--muted);
    font-size: 1rem;
    font-weight: 700;
    line-height: 1.65;
    margin: 0;
  }

  .homepage-grid {
    align-items: stretch;
    display: grid;
    gap: 28px;
    grid-template-columns: minmax(0, 1.2fr) minmax(250px, 0.48fr) minmax(280px, 0.45fr);
  }

  .lead-story {
    background: var(--panel);
    border: 1px solid var(--line);
    box-shadow: var(--shadow);
    display: grid;
  }

  .lead-story img {
    aspect-ratio: 16 / 10;
    object-fit: cover;
  }

  .lead-story div {
    padding: 24px;
  }

  .lead-story h2 {
    font-family: Georgia, "Times New Roman", serif;
    font-size: clamp(2rem, 4vw, 3.6rem);
    line-height: 0.96;
    margin: 10px 0 14px;
  }

  .lead-story h2 a:hover,
  .story-row h3 a:hover,
  .top-link:hover strong {
    color: var(--accent);
  }

  .lead-story p:not(.eyebrow) {
    color: var(--muted);
    font-size: 1.04rem;
    line-height: 1.65;
  }

  .story-meta {
    border-top: 1px solid var(--line);
    color: var(--soft);
    display: flex;
    flex-wrap: wrap;
    font-size: 0.8rem;
    font-weight: 900;
    gap: 12px;
    margin-top: 18px;
    padding-top: 14px;
    text-transform: uppercase;
  }

  .top-stack,
  .live-panel,
  .insight-rail,
  .category-board section {
    background: var(--panel);
    border: 1px solid var(--line);
    box-shadow: var(--shadow);
  }

  .rail-heading {
    border-bottom: 1px solid var(--line);
    padding: 18px;
  }

  .rail-heading strong,
  .insight-rail h2 {
    display: block;
    font-family: Georgia, "Times New Roman", serif;
    font-size: 1.8rem;
    line-height: 1;
  }

  .top-link {
    border-bottom: 1px solid var(--line);
    display: grid;
    gap: 12px;
    grid-template-columns: 34px 1fr;
    padding: 18px;
  }

  .top-link:last-child {
    border-bottom: 0;
  }

  .top-link > span {
    color: var(--accent);
    font-family: Georgia, "Times New Roman", serif;
    font-size: 1.5rem;
    font-weight: 900;
  }

  .top-link small,
  .latest-list small,
  .mini-card small {
    color: var(--soft);
    display: block;
    font-size: 0.75rem;
    font-weight: 900;
    letter-spacing: 0.04em;
    margin-bottom: 7px;
    text-transform: uppercase;
  }

  .top-link strong {
    font-size: 1rem;
    line-height: 1.35;
  }

  .live-panel {
    align-content: start;
    display: grid;
    gap: 14px;
    padding: 16px;
  }

  .time-card {
    background:
      linear-gradient(135deg, #143c46, #111214);
    color: #fff;
    display: grid;
    gap: 8px;
    padding: 20px;
  }

  .flag {
    border-radius: 3px;
    box-shadow: 0 0 0 1px rgba(255, 255, 255, 0.35);
    display: inline-block;
    height: 15px;
    overflow: hidden;
    position: relative;
    width: 24px;
  }

  .flag-uae {
    background:
      linear-gradient(90deg, #e31b23 0 25%, transparent 25%),
      linear-gradient(#009a44 0 33.33%, #fff 33.33% 66.66%, #000 66.66%);
  }

  .flag-india {
    background: linear-gradient(#ff9933 0 33.33%, #fff 33.33% 66.66%, #138808 66.66%);
  }

  .flag-us {
    background:
      linear-gradient(90deg, #3c3b6e 0 42%, transparent 42%),
      repeating-linear-gradient(#b22234 0 2px, #fff 2px 4px);
  }

  .time-card p {
    color: rgba(255, 255, 255, 0.72);
    font-size: 0.78rem;
    font-weight: 900;
    letter-spacing: 0.08em;
    margin: 0;
    text-transform: uppercase;
  }

  .time-card time {
    font-family: Georgia, "Times New Roman", serif;
    font-size: clamp(2.4rem, 4vw, 3.4rem);
    font-variant-numeric: tabular-nums;
    font-weight: 900;
    line-height: 1;
  }

  .time-card small,
  .world-times span {
    color: rgba(255, 255, 255, 0.68);
    font-weight: 800;
  }

  .weather-mini {
    border: 1px solid var(--line);
    padding: 16px;
  }

  .weather-mini strong {
    display: block;
    line-height: 1.35;
    margin-top: 4px;
  }

  .weather-pills {
    display: grid;
    gap: 8px;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    margin-top: 14px;
  }

  .weather-pills article {
    background: var(--paper);
    border: 1px solid var(--line);
    display: grid;
    gap: 3px;
    min-width: 0;
    padding: 10px;
  }

  .weather-pills span {
    color: var(--muted);
    font-size: 0.72rem;
    font-weight: 900;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .weather-pills strong {
    font-family: Georgia, "Times New Roman", serif;
    font-size: 1.5rem;
  }

  .weather-pills small {
    color: var(--soft);
    font-weight: 800;
  }

  .world-times {
    background: #111214;
    display: grid;
    gap: 1px;
  }

  .world-times span {
    align-items: center;
    background: rgba(255, 255, 255, 0.06);
    display: flex;
    gap: 8px;
    justify-content: space-between;
    padding: 10px 12px;
  }

  .world-times b {
    color: #fff;
    font-variant-numeric: tabular-nums;
  }

  .section-title {
    align-items: end;
    border-bottom: 1px solid var(--line);
    display: flex;
    justify-content: space-between;
    margin-bottom: 20px;
    padding-bottom: 16px;
  }

  .section-title h2 {
    font-family: Georgia, "Times New Roman", serif;
    font-size: clamp(1.8rem, 3vw, 3rem);
    line-height: 1;
    margin: 0;
    max-width: 680px;
    text-align: right;
  }

  .just-in-grid {
    display: grid;
    gap: 1px;
    grid-template-columns: repeat(7, minmax(0, 1fr));
  }

  .just-in-grid a {
    background: var(--panel);
    border: 1px solid var(--line);
    display: grid;
    gap: 10px;
    min-height: 170px;
    padding: 16px;
  }

  .just-in-grid a:hover {
    background: #fff;
    border-color: rgba(227, 59, 47, 0.35);
  }

  .just-in-grid span,
  .insight-rail span {
    color: var(--accent);
    font-size: 0.72rem;
    font-weight: 950;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .just-in-grid strong {
    font-family: Georgia, "Times New Roman", serif;
    font-size: 1.15rem;
    line-height: 1.12;
  }

  .just-in-grid small {
    align-self: end;
    color: var(--soft);
    font-size: 0.76rem;
    font-weight: 800;
  }

  .split-section {
    align-items: start;
