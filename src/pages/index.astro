---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { categories } from "../data/articles";
import { optimizedImage } from "../lib/images";

const articleTimestamp = (article) => {
  const [hour = "00", minute = "00"] = String(article.data.publishedTime || "").match(/\d{2}/g) || [];
  const date = new Date(article.data.date);
  date.setHours(Number(hour), Number(minute), 0, 0);
  return date.getTime();
};

const articles = (await getCollection("articles", ({ data }) => !data.draft))
  .sort((a, b) => articleTimestamp(b) - articleTimestamp(a));

const [leadArticle, ...restArticles] = articles;
const topStories = restArticles.slice(0, 4);
const justIn = articles.slice(0, 7);
const heroLiveNews = articles.slice(0, 5);
const latest = restArticles.slice(4, 16);
const opinionRail = articles.filter((article) => ["Business", "Technology", "Real Estate"].includes(article.data.category)).slice(0, 5);
const categoryBlocks = categories
  .map((category) => ({
    category,
    articles: articles.filter((article) => article.data.category === category).slice(0, 3),
  }))
  .filter((block) => block.articles.length);

const estimateRead = (article) => Math.max(3, Math.round((article.body || "").split(/\s+/).length / 220));

const emirates = [
  { name: "Abu Dhabi", label: "Capital", lat: 24.4539, lon: 54.3773, fallbackTemp: 31, fallbackWind: 24 },
  { name: "Dubai", label: "Business hub", lat: 25.2048, lon: 55.2708, fallbackTemp: 31, fallbackWind: 17 },
  { name: "Sharjah", label: "Culture", lat: 25.3463, lon: 55.4209, fallbackTemp: 30, fallbackWind: 16 },
  { name: "Ajman", label: "Coast", lat: 25.4052, lon: 55.5136, fallbackTemp: 31, fallbackWind: 19 },
  { name: "Fujairah", label: "East coast", lat: 25.1288, lon: 56.3265, fallbackTemp: 34, fallbackWind: 21 },
  { name: "Ras Al Khaimah", label: "Northern emirate", lat: 25.8007, lon: 55.9762, fallbackTemp: 31, fallbackWind: 20 },
  { name: "Umm Al Quwain", label: "Lagoon", lat: 25.5647, lon: 55.5552, fallbackTemp: 31, fallbackWind: 21 },
];

const marketItems = [
  { symbol: "GC=F", label: "Gold", unit: "XAU/USD", value: "4,481.86" },
  { symbol: "SI=F", label: "Silver", unit: "XAG/USD", value: "75.46" },
  { symbol: "CL=F", label: "Oil", unit: "US WTI", value: "102.40" },
  { symbol: "AED=X", label: "USD/AED", unit: "Dirham", value: "3.6725" },
  { symbol: "BTC-USD", label: "Bitcoin", unit: "BTC/USD", value: "77,443" },
  { symbol: "NQ=F", label: "Nasdaq", unit: "Futures", value: "29,076.5" },
];
---

<BaseLayout
  title="Dubai Time | UAE Business, Markets, Weather And Leadership News"
  description="Dubai Time is a UAE-first business and city news publication with live time, markets, weather and sharp context on Dubai."
>
  <section class="market-ticker" aria-label="Live markets ticker">
    <div class="market-label"><span></span>Markets</div>
    <div class="market-window">
      <div class="market-track">
        {[0, 1].map((loop) => (
          <div class="market-group" aria-hidden={loop === 1 ? "true" : undefined}>
            {marketItems.map((item) => (
              <span class="market-item">
                <strong>{item.label}</strong> <em>{item.unit}</em> <b data-market-symbol={item.symbol}>{item.value}</b>
              </span>
            ))}
            <span class="market-item"><strong>Updated</strong> <em data-market-updated>Checking feed</em></span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section masthead">
    <div class="hero-copy">
      <p class="eyebrow">Live UAE Time</p>
      <h1>UAE time, weather and market pulse.</h1>
      <p>
        A clean dashboard for Dubai time, seven-emirate weather, rain signals, wind and the market numbers people check through the day.
      </p>
    </div>

    <aside class="live-panel" id="weather" aria-label="Live UAE dashboard">
      <div class="time-card">
        <span class="flag flag-uae" aria-hidden="true"></span>
        <p>Live UAE Time</p>
        <time id="uae-clock" datetime="">--:--:--</time>
        <small id="uae-date">Loading Dubai time...</small>
        <div class="clock-weather-line">
          <span>Dubai now</span>
          <strong><b data-dubai-temp>31°</b> · <em data-dubai-condition>Clear sky</em></strong>
        </div>
      </div>
      <div class="weather-mini">
        <div>
          <p class="eyebrow">Seven Emirates Weather</p>
          <strong id="weather-alert">No major rain signal right now</strong>
        </div>
        <div class="weather-pills">
          {emirates.map((emirate) => (
            <article data-city={emirate.name} data-lat={emirate.lat} data-lon={emirate.lon}>
              <span>{emirate.name}</span>
              <strong data-temp>{emirate.fallbackTemp}°</strong>
              <small data-condition>Clear sky</small>
              <small><b data-rain>0%</b> rain · <b data-wind>{emirate.fallbackWind}</b> km/h wind</small>
            </article>
          ))}
        </div>
      </div>
      <div class="world-times">
        <span>UTC <b id="utc-clock">--:--</b></span>
        <span><span class="flag flag-india" aria-hidden="true"></span> India <b id="ist-clock">--:--</b></span>
        <span><span class="flag flag-us" aria-hidden="true"></span> New York <b id="ny-clock">--:--</b></span>
      </div>
    </aside>

    <div class="hero-live-news" aria-label="Live news">
      <div class="hero-live-heading">
        <span></span>
        <strong>Live News</strong>
      </div>
      <div class="hero-live-list">
        {heroLiveNews.map((article) => (
          <a href={`/articles/${article.id}`}>
            <span>{article.data.category}</span>
            <strong>{article.data.title}</strong>
            <small>{article.data.publishedTime}</small>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section homepage-grid" id="news">
    <article class="lead-story">
      <a href={`/articles/${leadArticle.id}`} aria-label={leadArticle.data.title}>
        <img src={optimizedImage(leadArticle.data.image)} alt={leadArticle.data.imageAlt} />
      </a>
      <div>
        <p class="eyebrow">{leadArticle.data.category}</p>
        <h2><a href={`/articles/${leadArticle.id}`}>{leadArticle.data.title}</a></h2>
        <p>{leadArticle.data.description}</p>
        <div class="story-meta">
          <span>{leadArticle.data.author}</span>
          <span>{leadArticle.data.publishedTime}</span>
          <span>{estimateRead(leadArticle)} min read</span>
        </div>
      </div>
    </article>

    <aside class="top-stack" aria-label="Top stories">
      <div class="rail-heading">
        <p class="eyebrow">Top Stories</p>
        <strong>What matters now</strong>
      </div>
      {topStories.map((article, index) => (
        <a href={`/articles/${article.id}`} class="top-link">
          <span>{String(index + 1).padStart(2, "0")}</span>
          <div>
            <small>{article.data.category} · {article.data.publishedTime}</small>
            <strong>{article.data.title}</strong>
          </div>
        </a>
      ))}
    </aside>

  </section>

  <section class="section quick-grid" aria-label="Just in">
    <div class="section-title">
      <p class="eyebrow">Just In</p>
      <h2>Latest from the desk</h2>
    </div>
    <div class="just-in-grid">
      {justIn.map((article) => (
        <a href={`/articles/${article.id}`}>
          <span>{article.data.category}</span>
          <strong>{article.data.title}</strong>
          <small>{article.data.publishedTime} · {estimateRead(article)} min read</small>
        </a>
      ))}
    </div>
  </section>

  <section class="section split-section">
    <div class="latest-column">
      <div class="section-title">
        <p class="eyebrow">Latest News Feed</p>
        <h2>Business, city and leadership updates</h2>
      </div>
      <div class="latest-list">
        {latest.map((article) => (
          <article class="story-row">
            <a href={`/articles/${article.id}`}>
              <img src={optimizedImage(article.data.image)} alt={article.data.imageAlt} loading="lazy" />
            </a>
            <div>
              <p class="eyebrow">{article.data.category}</p>
              <h3><a href={`/articles/${article.id}`}>{article.data.title}</a></h3>
              <p>{article.data.description}</p>
              <small>{article.data.publishedTime} · {estimateRead(article)} min read</small>
            </div>
          </article>
        ))}
      </div>
    </div>

    <aside class="insight-rail">
      <p class="eyebrow">Founder Lens</p>
      <h2>Reads for operators and investors</h2>
      {opinionRail.map((article) => (
        <a href={`/articles/${article.id}`}>
          <span>{article.data.category}</span>
          <strong>{article.data.title}</strong>
        </a>
      ))}
    </aside>
  </section>

  <section class="section category-board" aria-label="Dubai Time sections">
    <div class="section-title">
      <p class="eyebrow">Sections</p>
      <h2>Browse Dubai Time by desk</h2>
    </div>
    <div class="category-grid">
      {categoryBlocks.map((block) => (
        <section>
          <a class="category-name" href={`/category/${block.category.toLowerCase().replaceAll(" ", "-")}`}>{block.category}</a>
          {block.articles.map((article) => (
            <a class="mini-card" href={`/articles/${article.id}`}>
              <img src={optimizedImage(article.data.image)} alt={article.data.imageAlt} loading="lazy" />
              <strong>{article.data.title}</strong>
              <small>{article.data.publishedTime}</small>
            </a>
          ))}
        </section>
      ))}
    </div>
  </section>

  <script define:vars={{ emirates }}>
    const conditionText = {
      0: "Clear",
      1: "Mainly clear",
      2: "Partly cloudy",
      3: "Overcast",
      45: "Fog",
      51: "Light drizzle",
      61: "Slight rain",
      63: "Moderate rain",
      65: "Heavy rain",
      80: "Light showers",
      95: "Thunderstorm",
    };

    const formatTime = (timeZone, withSeconds = false) =>
      new Intl.DateTimeFormat("en-US", {
        timeZone,
        hour: "2-digit",
        minute: "2-digit",
        second: withSeconds ? "2-digit" : undefined,
        hour12: false,
      }).format(new Date());

    const updateClock = () => {
      const now = new Date();
      const uaeClock = document.getElementById("uae-clock");
      const uaeDate = document.getElementById("uae-date");
      if (uaeClock) {
        uaeClock.textContent = formatTime("Asia/Dubai", true);
        uaeClock.setAttribute("datetime", now.toISOString());
      }
      if (uaeDate) {
        uaeDate.textContent = new Intl.DateTimeFormat("en-US", {
          timeZone: "Asia/Dubai",
          weekday: "long",
          month: "long",
          day: "numeric",
          year: "numeric",
        }).format(now);
      }
      const utcClock = document.getElementById("utc-clock");
      const istClock = document.getElementById("ist-clock");
      const nyClock = document.getElementById("ny-clock");
      if (utcClock) utcClock.textContent = formatTime("UTC");
      if (istClock) istClock.textContent = formatTime("Asia/Kolkata");
      if (nyClock) nyClock.textContent = formatTime("America/New_York");
    };

    const buildWeatherUrl = () => {
      const latitudes = emirates.map((city) => city.lat).join(",");
      const longitudes = emirates.map((city) => city.lon).join(",");
      return `https://api.open-meteo.com/v1/forecast?latitude=${latitudes}&longitude=${longitudes}&current=temperature_2m,relative_humidity_2m,rain,weather_code,wind_speed_10m&hourly=precipitation_probability&forecast_days=1&timezone=Asia%2FDubai`;
    };

    const updateWeather = async () => {
      const alert = document.getElementById("weather-alert");
      try {
        const response = await fetch(buildWeatherUrl());
        if (!response.ok) throw new Error("Weather request failed");
        const payload = await response.json();
        const cityWeather = Array.isArray(payload) ? payload : [payload];
        let hottest = 0;
        let highestRain = 0;
        cityWeather.forEach((item, index) => {
          const card = document.querySelector(`[data-city="${emirates[index].name}"]`);
          if (!card || !item.current) return;
          const current = item.current;
          const rainChance = item.hourly?.precipitation_probability?.[0] ?? 0;
          const condition = conditionText[current.weather_code] || "Current weather";
          const wind = Math.round(current.wind_speed_10m || 0);
          hottest = Math.max(hottest, current.temperature_2m || 0);
          highestRain = Math.max(highestRain, rainChance, current.rain || 0);
          card.querySelector("[data-temp]").textContent = `${Math.round(current.temperature_2m)}°`;
          card.querySelector("[data-rain]").textContent = `${rainChance}%`;
          card.querySelector("[data-wind]").textContent = wind;
          card.querySelector("[data-condition]").textContent = condition;
          card.title = `${condition}, ${rainChance}% rain, ${wind} km/h wind`;
          if (emirates[index].name === "Dubai") {
            const dubaiTemp = document.querySelector("[data-dubai-temp]");
            const dubaiCondition = document.querySelector("[data-dubai-condition]");
            if (dubaiTemp) dubaiTemp.textContent = `${Math.round(current.temperature_2m)}°`;
            if (dubaiCondition) dubaiCondition.textContent = condition;
          }
        });
        if (alert) {
          alert.textContent =
            highestRain >= 30
              ? "Rain watch active in parts of the UAE"
              : hottest >= 38
                ? "Heat watch active across the Emirates"
                : "No major rain signal right now";
        }
      } catch {
        if (alert) alert.textContent = "Weather feed retrying";
      }
    };

    const fallbackMarkets = {
      "GC=F": 4481.86,
      "SI=F": 75.46,
      "CL=F": 102.4,
      "AED=X": 3.6725,
      "BTC-USD": 77443,
      "NQ=F": 29076.5,
    };
    const formatMarketValue = (symbol, value) => {
      if (!Number.isFinite(value) || value <= 0) return formatMarketValue(symbol, fallbackMarkets[symbol]);
      if (symbol === "AED=X") return value.toFixed(4);
      if (symbol === "BTC-USD") return value.toLocaleString("en-US", { maximumFractionDigits: 0 });
      if (symbol === "GC=F" || symbol === "SI=F" || symbol === "CL=F") {
        return value.toLocaleString("en-US", { maximumFractionDigits: 2 });
      }
      return value.toLocaleString("en-US", { maximumFractionDigits: 1 });
    };
    const setMarketValue = (symbol, value) => {
      document.querySelectorAll(`[data-market-symbol="${symbol}"]`).forEach((item) => {
        item.textContent = formatMarketValue(symbol, value);
      });
    };
    const updateMarkets = async () => {
      try {
        const response = await fetch("/api/markets");
        if (!response.ok) throw new Error("Market request failed");
        const payload = await response.json();
        Object.entries({ ...fallbackMarkets, ...(payload.markets || {}) }).forEach(([symbol, price]) => {
          const value = Number(price);
          if (Number.isFinite(value) && value > 0) setMarketValue(symbol, value);
        });
        document.querySelectorAll("[data-market-updated]").forEach((item) => {
          item.textContent = `${formatTime("Asia/Dubai")} GST`;
        });
      } catch {
        Object.entries(fallbackMarkets).forEach(([symbol, value]) => setMarketValue(symbol, value));
        document.querySelectorAll("[data-market-updated]").forEach((item) => {
          item.textContent = `${formatTime("Asia/Dubai")} GST`;
        });
      }
    };

    updateClock();
    updateWeather();
    updateMarkets();
    window.setInterval(updateClock, 1000);
    window.setInterval(updateWeather, 15 * 60 * 1000);
    window.setInterval(updateMarkets, 5 * 60 * 1000);
  </script>
</BaseLayout>

<style>
  .market-ticker {
    align-items: stretch;
    background: #111214;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    color: #fff;
    display: flex;
    overflow: hidden;
  }

  .market-label {
    align-items: center;
    background: var(--accent);
    color: #fff;
    display: flex;
    flex: 0 0 auto;
    font-size: 0.74rem;
    font-weight: 950;
    gap: 7px;
    letter-spacing: 0.06em;
    min-height: 34px;
    padding: 9px 18px;
    text-transform: uppercase;
  }

  .market-label span {
    background: #111214;
    border-radius: 50%;
    height: 7px;
    width: 7px;
  }

  .market-window {
    flex: 1;
    min-width: 0;
    overflow: hidden;
  }

  .market-track {
    display: flex;
    width: max-content;
    animation: ticker 28s linear infinite;
  }

  .market-window:hover .market-track {
    animation-play-state: paused;
  }

  .market-group {
    align-items: center;
    display: flex;
    gap: 24px;
    padding: 0 24px;
  }

  .market-item {
    align-items: center;
    display: flex;
    gap: 6px;
    min-height: 34px;
    white-space: nowrap;
  }

  .market-item strong {
    color: #fff;
    font-size: 0.74rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .market-item em,
  .market-item b {
    color: rgba(255, 255, 255, 0.62);
    font-size: 0.74rem;
    font-style: normal;
    font-weight: 800;
  }

  @keyframes ticker {
    to {
      transform: translateX(-50%);
    }
  }

  .masthead {
    align-items: start;
    border-bottom: 1px solid var(--line);
    display: grid;
    gap: 18px;
    grid-template-columns: 1fr;
    padding-bottom: 28px;
    padding-top: 24px;
  }

  .masthead h1 {
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
      sans-serif;
    font-size: clamp(2rem, 3.6vw, 3.55rem);
    font-weight: 900;
    letter-spacing: -0.034em;
    line-height: 1.04;
    margin: 8px 0 0;
    max-width: 760px;
  }

  .hero-copy {
    align-self: start;
    max-width: 830px;
    padding-top: 4px;
  }

  .hero-copy p:not(.eyebrow) {
    color: var(--muted);
    font-size: clamp(0.94rem, 1.3vw, 1.08rem);
    font-weight: 700;
    line-height: 1.55;
    margin: 14px 0 0;
    max-width: 760px;
  }

  .hero-live-news {
    background: #111214;
    box-shadow: var(--shadow);
    color: #fff;
    grid-column: 1;
    margin-top: 4px;
    max-width: none;
  }

  .hero-live-heading {
    align-items: center;
    border-bottom: 1px solid rgba(255, 255, 255, 0.12);
    display: flex;
    gap: 9px;
    padding: 12px 16px;
  }

  .hero-live-heading span {
    background: var(--accent);
    border-radius: 50%;
    box-shadow: 0 0 0 5px rgba(227, 59, 47, 0.18);
    height: 8px;
    width: 8px;
  }

  .hero-live-heading strong {
    font-size: 0.78rem;
    font-weight: 950;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .hero-live-list {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
  }

  .hero-live-list a {
    border-right: 1px solid rgba(255, 255, 255, 0.1);
    display: grid;
    gap: 9px;
    min-height: 145px;
    padding: 14px;
  }

  .hero-live-list a:last-child {
    border-right: 0;
  }

  .hero-live-list a:hover {
    background: rgba(255, 255, 255, 0.06);
  }

  .hero-live-list span {
    color: #ff5a4f;
    font-size: 0.68rem;
    font-weight: 950;
    letter-spacing: 0.07em;
    text-transform: uppercase;
  }

  .hero-live-list strong {
    font-family: Georgia, "Times New Roman", serif;
    font-size: 1rem;
    line-height: 1.12;
  }

  .hero-live-list small {
    align-self: end;
    color: rgba(255, 255, 255, 0.58);
    font-size: 0.72rem;
    font-weight: 850;
    text-transform: uppercase;
  }

  .homepage-grid {
    align-items: stretch;
    display: grid;
    gap: 28px;
    grid-template-columns: minmax(0, 1.22fr) minmax(285px, 0.48fr);
  }

  .lead-story {
    background: var(--panel);
    border: 1px solid var(--line);
    box-shadow: var(--shadow);
    display: grid;
  }

  .lead-story img {
    aspect-ratio: 16 / 10;
    object-fit: cover;
  }

  .lead-story div {
    padding: 24px;
  }

  .lead-story h2 {
    font-family: Georgia, "Times New Roman", serif;
    font-size: clamp(1.55rem, 2.8vw, 2.65rem);
    line-height: 1.02;
    margin: 10px 0 14px;
  }

  .lead-story h2 a:hover,
  .story-row h3 a:hover,
  .top-link:hover strong {
    color: var(--accent);
  }

  .lead-story p:not(.eyebrow) {
    color: var(--muted);
    font-size: 0.96rem;
    line-height: 1.65;
  }

  .story-meta {
    border-top: 1px solid var(--line);
    color: var(--soft);
    display: flex;
    flex-wrap: wrap;
    font-size: 0.8rem;
    font-weight: 900;
    gap: 12px;
    margin-top: 18px;
    padding-top: 14px;
    text-transform: uppercase;
  }

  .top-stack,
  .live-panel,
  .insight-rail,
  .category-board section {
    background: var(--panel);
    border: 1px solid var(--line);
    box-shadow: var(--shadow);
  }

  .rail-heading {
    border-bottom: 1px solid var(--line);
    padding: 18px;
  }

  .rail-heading strong,
  .insight-rail h2 {
    display: block;
    font-family: Georgia, "Times New Roman", serif;
    font-size: 1.45rem;
    line-height: 1.08;
  }

  .top-link {
    border-bottom: 1px solid var(--line);
    display: grid;
    gap: 12px;
    grid-template-columns: 34px 1fr;
    padding: 18px;
  }

  .top-link:last-child {
    border-bottom: 0;
  }

  .top-link > span {
    color: var(--accent);
    font-family: Georgia, "Times New Roman", serif;
    font-size: 1.5rem;
    font-weight: 900;
  }

  .top-link small,
  .latest-list small,
  .mini-card small {
    color: var(--soft);
    display: block;
    font-size: 0.75rem;
    font-weight: 900;
    letter-spacing: 0.04em;
    margin-bottom: 7px;
    text-transform: uppercase;
  }

  .top-link strong {
    font-size: 1rem;
    line-height: 1.35;
  }

  .live-panel {
    align-content: start;
    display: grid;
    gap: 0;
    grid-column: 1;
    grid-row: auto;
    grid-template-columns: minmax(270px, 0.9fr) minmax(0, 1.35fr) minmax(210px, 0.58fr);
    padding: 0;
    overflow: hidden;
  }

  .time-card {
    background:
