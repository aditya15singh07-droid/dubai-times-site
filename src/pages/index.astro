---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { categories } from "../data/articles";

const articles = (await getCollection("articles", ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const [leadArticle, ...moreArticles] = articles;
const estimateRead = (article) => Math.max(3, Math.round((article.body || "").split(/\s+/).length / 220));

const emirates = [
  { name: "Abu Dhabi", label: "Capital", lat: 24.4539, lon: 54.3773 },
  { name: "Dubai", label: "Business hub", lat: 25.2048, lon: 55.2708 },
  { name: "Sharjah", label: "Culture", lat: 25.3463, lon: 55.4209 },
  { name: "Ajman", label: "Coast", lat: 25.4052, lon: 55.5136 },
  { name: "Fujairah", label: "East coast", lat: 25.1288, lon: 56.3265 },
  { name: "Ras Al Khaimah", label: "Northern emirate", lat: 25.8007, lon: 55.9762 },
  { name: "Umm Al Quwain", label: "Lagoon", lat: 25.5647, lon: 55.5552 },
];

const liveNews = articles.slice(0, 4);
const editorPicks = categories
  .map((category) => articles.find((article) => article.data.category === category))
  .filter(Boolean)
  .slice(0, 4);
---

<BaseLayout
  title="Dubai Time | UAE Clock, Emirates Weather And Dubai News"
  description="Dubai Time shows the live UAE clock, seven-emirate weather, rain outlook, alerts, and curated Dubai news."
>
  <section class="time-hero" aria-label="Live UAE time">
    <div class="section time-grid">
      <div class="clock-card">
        <p class="eyebrow">Live UAE Time</p>
        <time class="main-clock" id="uae-clock" datetime="">--:--:--</time>
        <div class="clock-date" id="uae-date">Loading Dubai time...</div>
        <div class="clock-meta">
          <span>GST · UTC+4</span>
          <span>Auto-updating every second</span>
          <span id="sun-note">Weather desk loading</span>
        </div>
      </div>
      <aside class="clock-side" aria-label="Global reference times">
        <div>
          <span>UTC</span>
          <strong id="utc-clock">--:--</strong>
        </div>
        <div>
          <span>India</span>
          <strong id="ist-clock">--:--</strong>
        </div>
        <div>
          <span>New York</span>
          <strong id="ny-clock">--:--</strong>
        </div>
      </aside>
    </div>
  </section>

  <section class="section weather-desk" id="weather" aria-label="Seven emirates weather">
    <div class="weather-heading">
      <div>
        <p class="eyebrow">Seven Emirates Weather</p>
        <h1>Weather, rain chance and alerts across the UAE</h1>
      </div>
      <p>
        Live conditions are pulled in the browser for all seven emirates. Use this as a fast
        public dashboard before moving into the news.
      </p>
    </div>

    <div class="alert-panel" id="weather-alert">
      <span>Live Alert</span>
      <strong>Checking rain, wind and heat conditions...</strong>
    </div>

    <div class="weather-grid" data-weather-grid>
      {emirates.map((emirate) => (
        <article
          class="weather-card is-loading"
          data-city={emirate.name}
          data-label={emirate.label}
          data-lat={emirate.lat}
          data-lon={emirate.lon}
        >
          <div class="weather-top">
            <div>
              <span>{emirate.label}</span>
              <h2>{emirate.name}</h2>
            </div>
            <strong data-temp>--°</strong>
          </div>
          <p data-summary>Loading live conditions...</p>
          <div class="weather-metrics">
            <span><b data-rain>--%</b> rain</span>
            <span><b data-wind>--</b> wind</span>
            <span><b data-humidity>--%</b> humidity</span>
          </div>
          <small data-updated>Updating now</small>
        </article>
      ))}
    </div>
  </section>

  <section class="market-strip section" aria-label="Market snapshot">
    <span>Markets</span>
    <strong>Gold XAU/USD</strong>
    <b>Oil US WTI</b>
    <strong>USD/AED 3.6725</strong>
    <b>Bitcoin BTC/USD</b>
    <strong>Nasdaq Futures</strong>
  </section>

  <section class="section news-entry" id="news" aria-label="Dubai news">
    <div class="news-heading">
      <p class="eyebrow">News Desk</p>
      <h2>After time and weather, read the stories shaping Dubai</h2>
    </div>
    <article class="lead">
      <a href={`/articles/${leadArticle.id}`}>
        <img src={leadArticle.data.image} alt={leadArticle.data.imageAlt} />
      </a>
      <div class="lead-copy">
        <p class="eyebrow">{leadArticle.data.category}</p>
        <h3>
          <a href={`/articles/${leadArticle.id}`}>{leadArticle.data.title}</a>
        </h3>
        <p>{leadArticle.data.description}</p>
        <div class="meta">
          <span>{leadArticle.data.author}</span>
          <span>{leadArticle.data.date.toLocaleDateString("en-US", {
            month: "long",
            day: "numeric",
            year: "numeric",
          })} · {leadArticle.data.publishedTime}</span>
          <span>{estimateRead(leadArticle)} min read</span>
        </div>
      </div>
    </article>
  </section>

  <section class="section live-briefing" aria-label="Live briefing">
    <aside class="brief-card">
      <p class="eyebrow">Quick Brief</p>
      {liveNews.map((article) => (
        <a href={`/articles/${article.id}`}>
          <span>{article.data.category}</span>
          <strong>{article.data.title}</strong>
        </a>
      ))}
    </aside>
    <div class="editor-grid">
      {editorPicks.map((article) => (
        <a class="editor-pick" href={`/articles/${article.id}`}>
          <img src={article.data.image} alt={article.data.imageAlt} loading="lazy" />
          <span>{article.data.category}</span>
          <strong>{article.data.title}</strong>
          <small>{estimateRead(article)} min read · {article.data.publishedTime}</small>
        </a>
      ))}
    </div>
  </section>

  <section class="section category-strip" aria-label="Sections">
    {categories.map((category) => (
      <a href={`/category/${category.toLowerCase().replaceAll(" ", "-")}`}>
        {category}
      </a>
    ))}
  </section>

  <section class="section news-grid">
    <div class="section-heading">
      <p class="eyebrow">Latest</p>
      <h2>More From Dubai Time</h2>
    </div>
    <div class="cards">
      {moreArticles.map((article) => (
        <article class="story-card">
          <a href={`/articles/${article.id}`}>
            <img src={article.data.image} alt={article.data.imageAlt} loading="lazy" />
          </a>
          <div>
            <p class="eyebrow">{article.data.category}</p>
            <h3><a href={`/articles/${article.id}`}>{article.data.title}</a></h3>
            <p>{article.data.description}</p>
          </div>
        </article>
      ))}
    </div>
  </section>

  <script define:vars={{ emirates }}>
    const conditionText = {
      0: "Clear sky",
      1: "Mainly clear",
      2: "Partly cloudy",
      3: "Overcast",
      45: "Fog",
      48: "Depositing rime fog",
      51: "Light drizzle",
      53: "Moderate drizzle",
      55: "Dense drizzle",
      61: "Slight rain",
      63: "Moderate rain",
      65: "Heavy rain",
      71: "Slight snow",
      80: "Light rain showers",
      81: "Rain showers",
      82: "Heavy rain showers",
      95: "Thunderstorm",
    };

    const formatTime = (timeZone, withSeconds = false) =>
      new Intl.DateTimeFormat("en-US", {
        timeZone,
        hour: "2-digit",
        minute: "2-digit",
        second: withSeconds ? "2-digit" : undefined,
        hour12: false,
      }).format(new Date());

    const updateClock = () => {
      const now = new Date();
      const uaeClock = document.getElementById("uae-clock");
      const uaeDate = document.getElementById("uae-date");
      const utcClock = document.getElementById("utc-clock");
      const istClock = document.getElementById("ist-clock");
      const nyClock = document.getElementById("ny-clock");

      if (uaeClock) {
        uaeClock.textContent = formatTime("Asia/Dubai", true);
        uaeClock.setAttribute("datetime", now.toISOString());
      }
      if (uaeDate) {
        uaeDate.textContent = new Intl.DateTimeFormat("en-US", {
          timeZone: "Asia/Dubai",
          weekday: "long",
          month: "long",
          day: "numeric",
          year: "numeric",
        }).format(now);
      }
      if (utcClock) utcClock.textContent = formatTime("UTC");
      if (istClock) istClock.textContent = formatTime("Asia/Kolkata");
      if (nyClock) nyClock.textContent = formatTime("America/New_York");
    };

    const buildWeatherUrl = () => {
      const latitudes = emirates.map((city) => city.lat).join(",");
      const longitudes = emirates.map((city) => city.lon).join(",");
      return `https://api.open-meteo.com/v1/forecast?latitude=${latitudes}&longitude=${longitudes}&current=temperature_2m,relative_humidity_2m,precipitation,rain,weather_code,wind_speed_10m&hourly=precipitation_probability&forecast_days=1&timezone=Asia%2FDubai`;
    };

    const setWeatherError = () => {
      document.querySelectorAll(".weather-card").forEach((card) => {
        card.classList.remove("is-loading");
        card.querySelector("[data-summary]").textContent = "Live weather is temporarily unavailable.";
        card.querySelector("[data-updated]").textContent = "Please refresh in a few minutes.";
      });
      const alert = document.getElementById("weather-alert");
      if (alert) {
        alert.className = "alert-panel alert-watch";
        alert.querySelector("strong").textContent = "Weather feed is not responding. Keep official local alerts in view.";
      }
    };

    const updateWeather = async () => {
      try {
        const response = await fetch(buildWeatherUrl());
        if (!response.ok) throw new Error("Weather request failed");
        const payload = await response.json();
        const cityWeather = Array.isArray(payload) ? payload : [payload];
        let highestRain = 0;
        let strongestWind = 0;
        let hottest = 0;

        cityWeather.forEach((item, index) => {
          const card = document.querySelector(`[data-city="${emirates[index].name}"]`);
          if (!card || !item.current) return;

          const current = item.current;
          const rainChance = item.hourly?.precipitation_probability?.[0] ?? 0;
          highestRain = Math.max(highestRain, rainChance, current.rain || 0);
          strongestWind = Math.max(strongestWind, current.wind_speed_10m || 0);
          hottest = Math.max(hottest, current.temperature_2m || 0);

          card.classList.remove("is-loading");
          card.querySelector("[data-temp]").textContent = `${Math.round(current.temperature_2m)}°`;
          card.querySelector("[data-summary]").textContent = conditionText[current.weather_code] || "Current conditions";
          card.querySelector("[data-rain]").textContent = `${rainChance}%`;
          card.querySelector("[data-wind]").textContent = `${Math.round(current.wind_speed_10m)} km/h`;
          card.querySelector("[data-humidity]").textContent = `${Math.round(current.relative_humidity_2m)}%`;
          card.querySelector("[data-updated]").textContent = `Updated ${formatTime("Asia/Dubai")} GST`;

          card.classList.toggle("has-rain", rainChance >= 30 || current.rain > 0);
          card.classList.toggle("has-heat", current.temperature_2m >= 38);
        });

        const alert = document.getElementById("weather-alert");
        const sunNote = document.getElementById("sun-note");
        if (alert) {
          const message =
            highestRain >= 40
              ? "Rain watch active in parts of the UAE. Check roads, outdoor plans and official advisories."
              : strongestWind >= 35
                ? "Wind watch active. Outdoor visibility and exposed roads may need attention."
                : hottest >= 38
                  ? "Heat watch active. Hydration and midday outdoor exposure matter today."
                  : "No major rain or wind signal from the live weather feed right now.";
          alert.className = highestRain >= 40 || strongestWind >= 35 || hottest >= 38
            ? "alert-panel alert-watch"
            : "alert-panel alert-clear";
          alert.querySelector("strong").textContent = message;
        }
        if (sunNote) sunNote.textContent = `UAE weather refreshed ${formatTime("Asia/Dubai")} GST`;
      } catch {
        setWeatherError();
      }
    };

    updateClock();
    updateWeather();
    window.setInterval(updateClock, 1000);
    window.setInterval(updateWeather, 15 * 60 * 1000);
  </script>
</BaseLayout>

<style>
  .time-hero {
    background:
      linear-gradient(90deg, rgba(255, 255, 255, 0.08), transparent 32%, rgba(255, 255, 255, 0.06)),
      linear-gradient(135deg, #07131d 0%, #0d2d38 52%, #0b6e69 100%);
    color: #fffaf0;
  }

  .time-grid {
    align-items: stretch;
    display: grid;
    gap: 22px;
    grid-template-columns: minmax(0, 1fr) 310px;
    min-height: 460px;
    padding-bottom: 54px;
    padding-top: 54px;
  }

  .clock-card,
  .clock-side {
    backdrop-filter: blur(24px) saturate(1.18);
    background:
      linear-gradient(135deg, rgba(255, 255, 255, 0.16), rgba(255, 255, 255, 0.07)),
      linear-gradient(135deg, rgba(194, 145, 45, 0.08), rgba(11, 110, 105, 0.1));
    border: 1px solid rgba(255, 255, 255, 0.22);
    border-radius: 12px;
    box-shadow: 0 30px 80px rgba(0, 0, 0, 0.28);
  }

  .clock-card {
    container-type: inline-size;
    display: flex;
    flex-direction: column;
    justify-content: center;
    min-width: 0;
    overflow: hidden;
    padding: clamp(28px, 5vw, 58px);
  }

  .clock-card .eyebrow {
    color: #f4d99b;
  }

  .main-clock {
    font-family: Georgia, "Times New Roman", serif;
    font-size: clamp(4rem, 9vw, 7.7rem);
    font-variant-numeric: tabular-nums;
    font-weight: 800;
    letter-spacing: 0.01em;
    line-height: 0.92;
    max-width: 100%;
    overflow-wrap: normal;
    white-space: nowrap;
  }

  .clock-date {
    color: rgba(255, 250, 240, 0.86);
    font-size: clamp(1.1rem, 2vw, 1.55rem);
    font-weight: 800;
    margin-top: 22px;
  }

  .clock-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 26px;
  }

  .clock-meta span,
  .clock-side div {
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.14);
    border-radius: 999px;
    color: rgba(255, 250, 240, 0.88);
    font-size: 0.84rem;
    font-weight: 800;
    padding: 10px 13px;
  }

  .clock-side {
    display: grid;
    gap: 12px;
    padding: 22px;
  }

  .clock-side div {
    align-content: center;
    border-radius: 8px;
    display: grid;
    gap: 8px;
  }

  .clock-side span {
    color: #f4d99b;
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .clock-side strong {
    font-size: 2rem;
    font-variant-numeric: tabular-nums;
  }

  .weather-desk {
    background:
      linear-gradient(135deg, rgba(255, 255, 255, 0.74), rgba(255, 255, 255, 0.36));
    border: 1px solid rgba(255, 255, 255, 0.62);
    border-radius: 12px;
    box-shadow: 0 24px 70px rgba(7, 19, 24, 0.08);
    margin-top: 34px;
    padding-top: 34px;
  }

  .weather-heading {
    align-items: end;
    display: grid;
    gap: 24px;
    grid-template-columns: minmax(0, 1fr) minmax(260px, 0.38fr);
    margin-bottom: 22px;
  }

  .weather-heading h1,
  .news-heading h2,
  .section-heading h2 {
    font-family: Georgia, "Times New Roman", serif;
    font-size: clamp(2rem, 4.2vw, 3.7rem);
    line-height: 0.98;
    margin: 8px 0 0;
  }

  .weather-heading p:not(.eyebrow) {
    color: var(--muted);
    line-height: 1.65;
    margin: 0;
  }

  .alert-panel {
    align-items: center;
    backdrop-filter: blur(18px);
    background:
      linear-gradient(135deg, rgba(255, 255, 255, 0.88), rgba(255, 255, 255, 0.56));
    border: 1px solid rgba(222, 216, 205, 0.76);
    border-radius: 10px;
    display: flex;
    gap: 14px;
    justify-content: space-between;
    margin-bottom: 18px;
    padding: 15px 18px;
  }

  .alert-panel span {
    background: #111;
    border-radius: 999px;
    color: #fff;
    font-size: 0.78rem;
    font-weight: 900;
    letter-spacing: 0.08em;
    padding: 8px 12px;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .alert-panel strong {
    color: var(--muted);
    font-size: 0.95rem;
    line-height: 1.45;
    text-align: right;
  }

  .alert-clear span {
    background: var(--accent);
  }

  .alert-watch {
    border-color: rgba(194, 145, 45, 0.55);
    box-shadow: 0 14px 38px rgba(194, 145, 45, 0.13);
  }

  .alert-watch span {
    background: var(--gold);
    color: #111;
  }

  .weather-grid {
    display: grid;
    gap: 20px;
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  .weather-card {
    backdrop-filter: blur(18px);
    background:
      linear-gradient(135deg, rgba(255, 255, 255, 0.9), rgba(255, 255, 255, 0.55)),
      linear-gradient(135deg, rgba(11, 110, 105, 0.09), rgba(194, 145, 45, 0.07));
    border: 1px solid rgba(222, 216, 205, 0.78);
    border-radius: 10px;
    box-shadow: 0 18px 48px rgba(7, 19, 24, 0.09);
    display: flex;
    flex-direction: column;
    min-height: 254px;
    min-width: 0;
    overflow: hidden;
    padding: 20px;
    transition:
      transform 180ms ease,
      box-shadow 180ms ease,
      border-color 180ms ease;
  }

  .weather-card:hover {
    border-color: rgba(11, 110, 105, 0.42);
    box-shadow: 0 22px 52px rgba(7, 19, 24, 0.13);
    transform: translateY(-3px);
  }

  .weather-card.has-rain {
    border-color: rgba(8, 76, 97, 0.46);
  }

  .weather-card.has-heat {
    border-color: rgba(194, 145, 45, 0.52);
  }

  .weather-top {
    align-items: start;
    display: grid;
    gap: 12px;
    grid-template-columns: minmax(0, 1fr) auto;
  }

  .weather-top span {
    color: var(--gold);
    font-size: 0.72rem;
    font-weight: 900;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .weather-top h2 {
    font-family: Georgia, "Times New Roman", serif;
    font-size: clamp(1.28rem, 2vw, 1.7rem);
    line-height: 1.02;
    margin: 8px 0 0;
    overflow-wrap: anywhere;
  }

  .weather-top strong {
    color: var(--accent-strong);
    font-family: Georgia, "Times New Roman", serif;
    font-size: clamp(2rem, 3.2vw, 2.7rem);
    line-height: 0.95;
    white-space: nowrap;
  }

  .weather-card p {
    color: var(--muted);
    line-height: 1.5;
    margin: 18px 0;
    min-height: 48px;
  }

  .weather-metrics {
    display: grid;
    gap: 8px;
    margin-top: auto;
  }

  .weather-metrics span {
    align-items: center;
    border-top: 1px solid var(--line);
    color: var(--muted);
    display: flex;
    font-size: 0.82rem;
    font-weight: 800;
    justify-content: space-between;
    padding-top: 8px;
  }

  .weather-metrics b {
    color: var(--ink);
  }

  .weather-card small {
    color: var(--muted);
    display: block;
    font-size: 0.75rem;
    font-weight: 700;
    margin-top: 13px;
  }

  .market-strip {
    align-items: center;
    backdrop-filter: blur(18px);
    background:
      linear-gradient(135deg, rgba(255, 255, 255, 0.86), rgba(255, 255, 255, 0.54));
    border-bottom: 1px solid var(--line);
    border-top: 1px solid var(--line);
    display: flex;
    gap: 28px;
    max-width: none;
    overflow: hidden;
    padding-bottom: 13px;
    padding-top: 13px;
    white-space: nowrap;
  }

  .market-strip span {
    background: #111;
    border-radius: 999px;
    color: #fff;
    font-weight: 900;
    letter-spacing: 0.06em;
    padding: 8px 14px;
    text-transform: uppercase;
  }

  .market-strip strong {
    color: var(--accent-strong);
    font-size: 1.05rem;
    font-weight: 900;
  }

  .market-strip b {
    color: var(--muted);
    font-size: 1.05rem;
  }

  .news-entry {
    padding-top: 44px;
  }

  .news-heading {
    margin-bottom: 20px;
    max-width: 780px;
  }

  .lead {
    backdrop-filter: blur(18px);
    background:
      linear-gradient(135deg, rgba(255, 255, 255, 0.92), rgba(255, 255, 255, 0.58));
    border: 1px solid rgba(222, 216, 205, 0.78);
    border-radius: 10px;
    box-shadow: 0 24px 70px rgba(7, 19, 24, 0.13);
    display: grid;
    gap: 30px;
    grid-template-columns: minmax(0, 1.05fr) minmax(340px, 0.95fr);
    overflow: hidden;
  }

  .lead img {
    aspect-ratio: 16 / 10;
    height: 100%;
    object-fit: cover;
  }

  .lead-copy {
    align-self: center;
    padding: 26px 30px 26px 0;
  }

  .lead-copy h3 {
    font-family: Georgia, "Times New Roman", serif;
    font-size: clamp(2rem, 4.2vw, 3.8rem);
    line-height: 1;
    margin: 12px 0 18px;
  }

  .lead-copy > p:not(.eyebrow) {
    color: var(--muted);
    font-size: 1.06rem;
    line-height: 1.7;
  }

  .meta {
    color: var(--muted);
    display: flex;
    flex-wrap: wrap;
    font-size: 0.9rem;
    gap: 12px;
    margin-top: 24px;
  }

  .live-briefing {
    align-items: start;
    display: grid;
    gap: 22px;
    grid-template-columns: 340px minmax(0, 1fr);
    padding-bottom: 18px;
  }

  .brief-card,
  .editor-pick,
  .story-card {
    backdrop-filter: blur(18px);
    background:
      linear-gradient(135deg, rgba(255, 255, 255, 0.9), rgba(255, 255, 255, 0.54));
    border: 1px solid rgba(222, 216, 205, 0.76);
    border-radius: 10px;
    box-shadow: 0 14px 34px rgba(7, 19, 24, 0.07);
  }

  .brief-card {
    display: grid;
    gap: 12px;
    padding: 20px;
  }

  .brief-card a {
    border-top: 1px solid var(--line);
    display: grid;
    gap: 6px;
    padding-top: 12px;
  }

  .brief-card span,
  .editor-pick span {
    color: var(--accent);
    font-size: 0.72rem;
    font-weight: 900;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .brief-card strong {
    line-height: 1.35;
  }

  .editor-grid {
