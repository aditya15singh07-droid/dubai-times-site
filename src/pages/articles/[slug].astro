---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection, render } from "astro:content";
import { optimizedImage } from "../../lib/images";
import { categoryPath } from "../../data/articles";

export async function getStaticPaths() {
  const articles = await getCollection("articles", ({ data }) => !data.draft);
  return articles.map((article) => ({
    params: { slug: article.id },
    props: { article },
  }));
}

const articleTimestamp = (entry) => {
  const [hour = "00", minute = "00"] = String(entry.data.publishedTime || "").match(/\d{2}/g) || [];
  const date = new Date(entry.data.date);
  date.setHours(Number(hour), Number(minute), 0, 0);
  return date.getTime();
};

const { article } = Astro.props;
const { Content } = await render(article);
const siteUrl = "https://dubai-time.com";
const allArticles = (await getCollection("articles", ({ data }) => !data.draft))
  .sort((a, b) => articleTimestamp(b) - articleTimestamp(a));

const estimateRead = (entry) => Math.max(3, Math.round((entry.body || "").split(/\s+/).length / 220));
const readingMinutes = estimateRead(article);
const latestArticles = allArticles.filter((entry) => entry.id !== article.id).slice(0, 5);
const relatedArticles = allArticles
  .filter((entry) => entry.id !== article.id && entry.data.category === article.data.category)
  .slice(0, 3);
const fallbackRelated = allArticles
  .filter((entry) => entry.id !== article.id && !relatedArticles.some((related) => related.id === entry.id))
  .slice(0, 3 - relatedArticles.length);
const recommendedArticles = [...relatedArticles, ...fallbackRelated];
const canonicalUrl = `${siteUrl}/articles/${article.id}`;
const articleJsonLd = {
  "@context": "https://schema.org",
  "@type": "NewsArticle",
  mainEntityOfPage: {
    "@type": "WebPage",
    "@id": canonicalUrl,
  },
  headline: article.data.title,
  description: article.data.description,
  image: [new URL(optimizedImage(article.data.image), siteUrl).toString()],
  datePublished: article.data.date.toISOString(),
  dateModified: article.data.date.toISOString(),
  author: {
    "@type": "Person",
    name: article.data.author,
  },
  publisher: {
    "@type": "NewsMediaOrganization",
    name: "Dubai Time",
    logo: {
      "@type": "ImageObject",
      url: `${siteUrl}/favicon.svg`,
    },
  },
  articleSection: article.data.category,
  keywords: article.data.tags.join(", "),
  wordCount: article.body.split(/\s+/).filter(Boolean).length,
  timeRequired: `PT${readingMinutes}M`,
  inLanguage: "en",
  isAccessibleForFree: true,
};
---

<BaseLayout
  title={`${article.data.title} | Dubai Time`}
  description={article.data.description}
  canonical={canonicalUrl}
  type="article"
  structuredData={articleJsonLd}
>
  <div class="reading-progress" aria-hidden="true"><span data-reading-progress></span></div>

  <article class="article-shell">
    <header class="article-hero">
      <div class="article-kicker">
        <a href={`/category/${categoryPath(article.data.category)}`}>{article.data.category}</a>
        <span>Dubai Time</span>
      </div>
      <h1>{article.data.title}</h1>
      <p class="dek">{article.data.description}</p>
      <div class="author-row">
        <div>
          <span>By {article.data.author}</span>
          <strong>{article.data.date.toLocaleDateString("en-US", {
            month: "long",
            day: "numeric",
            year: "numeric",
          })} · {article.data.publishedTime}</strong>
        </div>
        <div>
          <span>Read Time</span>
          <strong>{readingMinutes} minutes</strong>
        </div>
      </div>
    </header>

    <figure class="article-image">
      <img src={optimizedImage(article.data.image)} alt={article.data.imageAlt} />
      {article.data.imageCredit && (
        <figcaption>
          {article.data.imageCreditUrl ? (
            <a href={article.data.imageCreditUrl} target="_blank" rel="noreferrer">{article.data.imageCredit}</a>
          ) : (
            article.data.imageCredit
          )}
        </figcaption>
      )}
    </figure>

    <div class="article-layout">
      <aside class="share-rail" aria-label="Article summary">
        <span>Brief</span>
        <p>{article.data.watchLine}</p>
        <a href="/">Dubai Time</a>
      </aside>

      <div class="article-body">
        <Content />
      </div>

      <aside class="latest-rail" aria-label="Latest stories">
        <p class="eyebrow">Latest</p>
        {latestArticles.map((entry) => (
          <a href={`/articles/${entry.id}`}>
            <span>{entry.data.category}</span>
            <strong>{entry.data.title}</strong>
          </a>
        ))}
      </aside>
    </div>

    <footer class="article-tags" aria-label="Article tags">
      {article.data.tags.map((tag) => <span>{tag}</span>)}
    </footer>

    <section class="continue-reading" aria-label="Continue reading">
      <div class="section-title">
        <p class="eyebrow">Continue Reading</p>
        <h2>More from Dubai Time</h2>
      </div>
      <div class="continue-grid">
        {recommendedArticles.map((entry) => (
          <a href={`/articles/${entry.id}`}>
            <img src={optimizedImage(entry.data.image)} alt={entry.data.imageAlt} loading="lazy" />
            <span>{entry.data.category}</span>
            <strong>{entry.data.title}</strong>
            <small>{estimateRead(entry)} min read · {entry.data.publishedTime}</small>
          </a>
        ))}
      </div>
    </section>
  </article>

  <script>
    const progress = document.querySelector("[data-reading-progress]");
    const article = document.querySelector(".article-body");

    const updateProgress = () => {
      if (!progress || !article) return;
      const rect = article.getBoundingClientRect();
      const total = rect.height - window.innerHeight * 0.35;
      const read = Math.min(Math.max(-rect.top, 0), Math.max(total, 1));
      progress.style.transform = `scaleX(${read / Math.max(total, 1)})`;
    };

    updateProgress();
    window.addEventListener("scroll", updateProgress, { passive: true });
    window.addEventListener("resize", updateProgress);
  </script>
</BaseLayout>

<style>
  .reading-progress {
    background: rgba(228, 225, 220, 0.9);
    height: 3px;
    inset: 0 0 auto;
    position: sticky;
    top: 0;
    z-index: 40;
  }

  .reading-progress span {
    background: var(--accent);
    display: block;
    height: 100%;
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 120ms linear;
  }

  .article-shell {
    margin: 0 auto;
    max-width: 1180px;
    padding: 44px 24px 0;
  }

  .article-hero {
    border-bottom: 1px solid var(--line);
    max-width: 900px;
    padding-bottom: 28px;
  }

  .article-kicker {
    align-items: center;
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }

  .article-kicker a,
  .article-kicker span {
    color: var(--accent);
    font-size: 0.78rem;
    font-weight: 950;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .article-kicker span {
    color: var(--soft);
  }

  h1 {
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
      sans-serif;
    font-size: clamp(1.15rem, 2vw, 1.85rem);
    letter-spacing: -0.018em;
    line-height: 1.18;
    margin: 16px 0 20px;
  }

  .dek {
    color: #3f4148;
    font-size: clamp(1rem, 1.5vw, 1.16rem);
    font-weight: 650;
    line-height: 1.55;
    margin: 0;
    max-width: 760px;
  }

  .author-row {
    display: flex;
    flex-wrap: wrap;
    gap: 26px;
    margin-top: 24px;
  }

  .author-row div {
    border-left: 3px solid var(--accent);
    display: grid;
    gap: 5px;
    padding-left: 12px;
  }

  .author-row span {
    color: var(--soft);
    font-size: 0.76rem;
    font-weight: 950;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .author-row strong {
    font-size: 0.95rem;
  }

  .article-image {
    margin: 30px 0 0;
  }

  .article-image img {
    aspect-ratio: 16 / 8.5;
    object-fit: cover;
  }

  .article-image figcaption {
    color: var(--soft);
    font-size: 0.78rem;
    margin-top: 8px;
    text-align: right;
  }

  .article-image a {
    text-decoration: underline;
  }

  .article-layout {
    align-items: start;
    display: grid;
    gap: 34px;
    grid-template-columns: 150px minmax(0, 720px) 270px;
    margin-top: 38px;
  }

  .share-rail,
  .latest-rail {
    position: sticky;
    top: 116px;
  }

  .share-rail {
    border-top: 3px solid var(--accent);
    color: var(--muted);
    display: grid;
    gap: 12px;
    padding-top: 14px;
  }

  .share-rail span,
  .latest-rail span,
  .continue-grid span {
    color: var(--accent);
    font-size: 0.72rem;
    font-weight: 950;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .share-rail p {
    font-size: 0.9rem;
    font-weight: 700;
    line-height: 1.55;
    margin: 0;
  }

  .share-rail a {
    background: #111214;
    color: #fff;
    font-size: 0.78rem;
    font-weight: 900;
    justify-self: start;
    padding: 9px 11px;
    text-transform: uppercase;
  }

  .article-body {
    background: var(--panel);
    border: 1px solid var(--line);
    box-shadow: var(--shadow);
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
      sans-serif;
    font-size: 0.98rem;
    hyphens: none;
    line-height: 1.72;
    overflow-wrap: normal;
    padding: clamp(24px, 4vw, 42px);
    text-align: justify;
    text-justify: inter-word;
    word-break: normal;
  }

  .article-body :global(h2) {
    border-top: 1px solid var(--line);
    color: var(--ink);
    font-family: Inter, ui-sans-serif, system-ui, sans-serif;
    font-size: 0.78rem;
    letter-spacing: 0.12em;
    line-height: 1.2;
    margin: 34px 0 14px;
    padding-top: 20px;
    text-transform: uppercase;
  }

  .article-body :global(p) {
    margin: 0 0 20px;
    hyphens: none;
    overflow-wrap: normal;
    text-align: justify;
    text-justify: inter-word;
    word-break: normal;
  }

  .article-body :global(a) {
    border-bottom: 1px solid rgba(227, 59, 47, 0.5);
    color: var(--accent-strong);
    font-weight: 800;
  }

  .latest-rail {
    background: var(--panel);
    border: 1px solid var(--line);
    padding: 18px;
  }

  .latest-rail a {
    border-top: 1px solid var(--line);
    display: grid;
    gap: 8px;
    padding: 14px 0;
  }

  .latest-rail strong {
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
      sans-serif;
    font-size: 0.9rem;
    line-height: 1.22;
  }

  .article-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin: 28px auto 0;
    max-width: 720px;
  }

  .article-tags span {
    background: #fff;
    border: 1px solid var(--line);
    color: var(--accent-strong);
    font-size: 0.82rem;
    font-weight: 900;
    padding: 8px 10px;
  }

  .continue-reading {
    border-top: 1px solid var(--line);
    margin-top: 46px;
    padding-top: 28px;
  }

  .section-title {
    align-items: end;
    display: flex;
    justify-content: space-between;
    margin-bottom: 18px;
  }

  .section-title h2 {
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
      sans-serif;
    font-size: clamp(1rem, 1.8vw, 1.3rem);
    line-height: 1.2;
    margin: 0;
  }

  .continue-grid {
    display: grid;
    gap: 18px;
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .continue-grid a {
    background: var(--panel);
    border: 1px solid var(--line);
    display: grid;
    gap: 11px;
    padding-bottom: 16px;
  }

  .continue-grid img {
    aspect-ratio: 16 / 10;
    object-fit: cover;
  }

  .continue-grid span,
  .continue-grid strong,
  .continue-grid small {
    margin-left: 16px;
    margin-right: 16px;
  }

  .continue-grid strong {
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
      sans-serif;
    font-size: 0.88rem;
    line-height: 1.24;
  }

  .continue-grid small {
    color: var(--soft);
    font-weight: 800;
  }

  @media (max-width: 1050px) {
    .article-layout {
      grid-template-columns: 1fr;
    }

    .share-rail,
    .latest-rail {
      position: static;
    }

    .latest-rail {
      display: none;
    }
  }

  @media (max-width: 720px) {
    .article-shell {
      padding: 30px 18px 0;
    }

    h1 {
      font-size: clamp(1.25rem, 5.4vw, 1.75rem);
      letter-spacing: -0.012em;
      line-height: 1.18;
    }

    .article-image img {
      aspect-ratio: 4 / 3;
    }

    .continue-grid {
      grid-template-columns: 1fr;
    }

    .section-title {
      align-items: flex-start;
      flex-direction: column;
      gap: 6px;
    }
  }
</style>
