---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const articles = await getCollection("articles", ({ data }) => !data.draft);
  return articles.map((article) => ({
    params: { slug: article.id },
    props: { article },
  }));
}

const { article } = Astro.props;
const { Content } = await render(article);
const focusTags = article.data.tags.slice(0, 3).join(", ");
---

<BaseLayout title={`${article.data.title} | Dubai Times`} description={article.data.description}>
  <article class="article section">
    <header class="article-header">
      <p class="eyebrow">{article.data.category}</p>
      <h1>{article.data.title}</h1>
      <p class="dek">{article.data.description}</p>
      <div class="meta">
        <span>{article.data.author}</span>
        <span>{article.data.date.toLocaleDateString("en-US", {
          month: "long",
          day: "numeric",
          year: "numeric",
        })} · {article.data.publishedTime}</span>
      </div>
    </header>
    <img class="hero-image" src={article.data.image} alt={article.data.imageAlt} />
    <section class="reader-brief" aria-label="Reader brief">
      <div>
        <span>Brief</span>
        <strong>{article.data.description}</strong>
      </div>
      <div>
        <span>Focus</span>
        <strong>{focusTags || article.data.category}</strong>
      </div>
      <div>
        <span>Watch</span>
        <strong>{article.data.watchLine}</strong>
      </div>
    </section>
    <div class="article-body">
      <Content />
    </div>
    <footer class="tags" aria-label="Article tags">
      {article.data.tags.map((tag) => <span>{tag}</span>)}
    </footer>
  </article>
</BaseLayout>

<style>
  .article {
    max-width: 980px;
  }

  .article-header {
    margin: 0 auto 28px;
    max-width: 800px;
    text-align: center;
  }

  h1 {
    font-family: Georgia, "Times New Roman", serif;
    font-size: clamp(2.4rem, 6vw, 5.4rem);
    line-height: 0.96;
    margin: 14px 0 18px;
  }

  .dek {
    color: var(--muted);
    font-size: 1.2rem;
    line-height: 1.7;
    margin: 0;
  }

  .meta {
    color: var(--muted);
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    justify-content: center;
    margin-top: 22px;
  }

  .hero-image {
    aspect-ratio: 16 / 9;
    object-fit: cover;
  }

  .reader-brief {
    background:
      linear-gradient(135deg, rgba(255, 255, 255, 0.94), rgba(248, 245, 238, 0.88)),
      radial-gradient(circle at top right, rgba(194, 145, 45, 0.12), transparent 38%);
    border: 1px solid var(--line);
    display: grid;
    gap: 1px;
    grid-template-columns: 1.2fr 0.8fr 1fr;
    margin: 22px auto 0;
    max-width: 900px;
  }

  .reader-brief div {
    background: rgba(255, 255, 255, 0.5);
    display: grid;
    gap: 8px;
    padding: 16px;
  }

  .reader-brief span {
    color: var(--gold);
    font-size: 0.72rem;
    font-weight: 900;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .reader-brief strong {
    color: var(--ink);
    font-size: 0.94rem;
    line-height: 1.45;
  }

  .article-body {
    font-family: Georgia, "Times New Roman", serif;
    font-size: 1.2rem;
    line-height: 1.85;
    margin: 34px auto 0;
    max-width: 720px;
  }

  .article-body h2 {
    border-top: 1px solid var(--line);
    color: var(--ink);
    font-family: Inter, ui-sans-serif, system-ui, sans-serif;
    font-size: 0.9rem;
    letter-spacing: 0.12em;
    line-height: 1.2;
    margin: 34px 0 14px;
    padding-top: 20px;
    text-transform: uppercase;
  }

  .article-body p {
    margin: 0 0 20px;
  }

  .article-body ul {
    font-family: Inter, ui-sans-serif, system-ui, sans-serif;
    font-size: 1rem;
    line-height: 1.7;
    margin: 0 0 24px;
    padding-left: 22px;
  }

  .article-body li {
    margin-bottom: 8px;
  }

  .article-body a {
    border-bottom: 1px solid rgba(194, 145, 45, 0.55);
    color: var(--accent-strong);
    font-weight: 700;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin: 30px auto 0;
    max-width: 720px;
  }

  .tags span {
    border: 1px solid var(--line);
    border-radius: 4px;
    color: var(--accent-strong);
    font-size: 0.9rem;
    font-weight: 800;
    padding: 8px 10px;
  }

  @media (max-width: 760px) {
    .reader-brief {
      grid-template-columns: 1fr;
    }
  }
</style>
