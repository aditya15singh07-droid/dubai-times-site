---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Manual Admin | Dubai Time"
  description="A simple manual article drafting page for Dubai Time."
>
  <section class="section login-shell" data-login-panel>
    <form class="login-card" data-login-form>
      <p class="eyebrow">Private Access</p>
      <h1>Dubai Time Admin</h1>
      <p>Enter your admin username and password to unlock the manual article draft panel.</p>
      <label>
        Username
        <input name="username" autocomplete="username" required />
      </label>
      <label>
        Password
        <input name="password" type="password" autocomplete="current-password" required />
      </label>
      <button type="submit">Unlock Admin</button>
      <p class="login-error" data-login-error></p>
    </form>
  </section>

  <section class="section admin-shell" data-admin-panel hidden>
    <header class="admin-header">
      <p class="eyebrow">Manual Admin</p>
      <h1>Create a Dubai Time article draft</h1>
      <p>
        Fill the story details, paste your image URL, and generate a clean markdown article
        file plus the public link format. This page does not publish by itself yet.
      </p>
      <button class="logout-button" type="button" data-logout>Lock Admin</button>
    </header>

    <form class="admin-form" data-admin-form>
      <label>
        Title
        <input name="title" required placeholder="Dubai Metro update changes daily commute..." />
      </label>
      <label>
        Category
        <select name="category">
          <option>Dubai</option>
          <option>UAE</option>
          <option>Business</option>
          <option>Real Estate</option>
          <option>Travel</option>
          <option>Lifestyle</option>
          <option>Technology</option>
          <option>World</option>
        </select>
      </label>
      <label>
        Short description
        <textarea name="description" rows="3" required placeholder="One tight summary for homepage cards."></textarea>
      </label>
      <label>
        Image URL
        <input name="image" required placeholder="https://images.pexels.com/photos/..." />
      </label>
      <label>
        Image alt text
        <input name="imageAlt" required placeholder="Dubai skyline at sunset..." />
      </label>
      <label>
        Watch line
        <input name="watchLine" placeholder="Watch how this affects commuters, investors or residents." />
      </label>
      <label>
        Tags
        <input name="tags" placeholder="Dubai, Transport, RTA" />
      </label>
      <label>
        Full article body
        <textarea name="body" rows="14" required placeholder="Write or paste the full story here. Use short paragraphs."></textarea>
      </label>
      <button type="submit">Generate Article File</button>
    </form>

    <section class="admin-output" aria-label="Generated article output">
      <div>
        <p class="eyebrow">Article Link</p>
        <code data-link>/articles/your-slug</code>
      </div>
      <div>
        <p class="eyebrow">Markdown File</p>
        <textarea data-output rows="22" readonly placeholder="Your generated markdown will appear here."></textarea>
      </div>
    </section>
  </section>

  <script>
    const loginPanel = document.querySelector("[data-login-panel]");
    const adminPanel = document.querySelector("[data-admin-panel]");
    const loginForm = document.querySelector("[data-login-form]");
    const loginError = document.querySelector("[data-login-error]");
    const logout = document.querySelector("[data-logout]");
    const form = document.querySelector("[data-admin-form]");
    const output = document.querySelector("[data-output]");
    const link = document.querySelector("[data-link]");
    const validUsernameHash = "1c8404be8725011bb83cb1257571eb0ee8e09571c6ca031b779268b45e878d3a";
    const validPasswordHash = "0762dcffc1d8f9640a520d6317b990a7b3c6f7cd981141820ab56b548e1297b0";

    const hashText = async (value) => {
      const bytes = new TextEncoder().encode(value);
      const digest = await crypto.subtle.digest("SHA-256", bytes);
      return Array.from(new Uint8Array(digest))
        .map((byte) => byte.toString(16).padStart(2, "0"))
        .join("");
    };

    const setUnlocked = (unlocked) => {
      if (loginPanel) loginPanel.hidden = unlocked;
      if (adminPanel) adminPanel.hidden = !unlocked;
      window.localStorage.setItem("dubai-time-admin", unlocked ? "unlocked" : "locked");
    };

    if (window.localStorage.getItem("dubai-time-admin") === "unlocked") {
      setUnlocked(true);
    }

    loginForm?.addEventListener("submit", async (event) => {
      event.preventDefault();
      const data = new FormData(loginForm);
      const usernameHash = await hashText(String(data.get("username") || ""));
      const passwordHash = await hashText(String(data.get("password") || ""));
      const ok = usernameHash === validUsernameHash && passwordHash === validPasswordHash;

      if (!ok) {
        if (loginError) loginError.textContent = "Wrong username or password.";
        return;
      }

      if (loginError) loginError.textContent = "";
      loginForm.reset();
      setUnlocked(true);
    });

    logout?.addEventListener("click", () => {
      setUnlocked(false);
    });

    const slugify = (value) =>
      value
        .toLowerCase()
        .replace(/['"]/g, "")
        .replace(/[^a-z0-9]+/g, "-")
        .replace(/^-|-$/g, "")
        .slice(0, 80);

    const escapeYaml = (value) => String(value || "").replaceAll('"', '\\"');

    form?.addEventListener("submit", (event) => {
      event.preventDefault();
      const data = new FormData(form);
      const title = data.get("title");
      const slug = slugify(title);
      const today = new Intl.DateTimeFormat("en-CA", {
        timeZone: "Asia/Dubai",
        year: "numeric",
        month: "2-digit",
        day: "2-digit",
      }).format(new Date());
      const time = new Intl.DateTimeFormat("en-US", {
        timeZone: "Asia/Dubai",
        hour: "2-digit",
        minute: "2-digit",
        hour12: false,
      }).format(new Date());
      const tags = String(data.get("tags") || "")
        .split(",")
        .map((tag) => tag.trim())
        .filter(Boolean)
        .map((tag) => `"${escapeYaml(tag)}"`)
        .join(", ");

      const markdown = `---
title: "${escapeYaml(title)}"
description: "${escapeYaml(data.get("description"))}"
category: "${escapeYaml(data.get("category"))}"
author: "Dubai Time Desk"
date: ${today}
publishedTime: "${time} GST"
watchLine: "${escapeYaml(data.get("watchLine") || "Watch the next official update and public response.")}"
image: "${escapeYaml(data.get("image"))}"
imageAlt: "${escapeYaml(data.get("imageAlt"))}"
tags: [${tags}]
draft: false
---

${data.get("body")}
`;

      if (output) output.value = markdown;
      if (link) link.textContent = `/articles/${slug}`;
    });
  </script>
</BaseLayout>

<style>
  .login-shell {
    max-width: 620px;
    min-height: 68vh;
  }

  .login-card {
    backdrop-filter: blur(20px) saturate(1.14);
    background:
      linear-gradient(135deg, rgba(255, 255, 255, 0.92), rgba(255, 255, 255, 0.56));
    border: 1px solid rgba(222, 216, 205, 0.78);
    border-radius: 12px;
    box-shadow: 0 24px 70px rgba(7, 19, 24, 0.11);
    display: grid;
    gap: 16px;
    padding: 28px;
  }

  .login-card h1 {
    font-family: Georgia, "Times New Roman", serif;
    font-size: clamp(2.4rem, 6vw, 4.5rem);
    line-height: 0.98;
    margin: 0;
  }

  .login-card p:not(.eyebrow):not(.login-error) {
    color: var(--muted);
    line-height: 1.6;
    margin: 0;
  }

  .login-error {
    color: #b42318;
    font-size: 0.9rem;
    font-weight: 800;
    margin: 0;
    min-height: 1.2em;
  }

  .admin-shell {
    display: grid;
    gap: 24px;
    grid-template-columns: minmax(0, 0.9fr) minmax(320px, 0.7fr);
  }

  .admin-header {
    grid-column: 1 / -1;
    max-width: 780px;
  }

  .admin-header h1 {
    font-family: Georgia, "Times New Roman", serif;
    font-size: clamp(2.4rem, 5vw, 4.8rem);
    line-height: 0.98;
    margin: 10px 0 14px;
  }

  .admin-header p:not(.eyebrow) {
    color: var(--muted);
    font-size: 1.08rem;
    line-height: 1.65;
  }

  .logout-button {
    background: #111;
    margin-top: 12px;
    width: fit-content;
  }

  .admin-form,
  .admin-output {
    backdrop-filter: blur(18px);
    background:
      linear-gradient(135deg, rgba(255, 255, 255, 0.92), rgba(255, 255, 255, 0.56));
    border: 1px solid rgba(222, 216, 205, 0.78);
    border-radius: 10px;
    box-shadow: 0 18px 48px rgba(7, 19, 24, 0.09);
    display: grid;
    gap: 16px;
    padding: 22px;
  }

  label {
    color: var(--accent-strong);
    display: grid;
    font-size: 0.86rem;
    font-weight: 900;
    gap: 7px;
  }

  input,
  select,
  textarea {
    border: 1px solid var(--line);
    border-radius: 6px;
    color: var(--ink);
    font: inherit;
    padding: 12px;
    width: 100%;
  }

  textarea {
    line-height: 1.55;
    resize: vertical;
  }

  button {
    background: var(--accent-strong);
    border: 0;
    border-radius: 6px;
    color: #fff;
    cursor: pointer;
    font: inherit;
    font-weight: 900;
    padding: 13px 16px;
  }

  code {
    background: #f4efe4;
    border: 1px solid var(--line);
    border-radius: 6px;
    color: var(--accent-strong);
    display: block;
    font-size: 1rem;
    overflow-wrap: anywhere;
    padding: 13px;
  }

  [data-output] {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", monospace;
    font-size: 0.82rem;
  }

  @media (max-width: 860px) {
    .admin-shell {
      grid-template-columns: 1fr;
    }
  }
</style>
