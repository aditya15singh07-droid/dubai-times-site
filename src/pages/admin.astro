---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Manual Admin | Dubai Time"
  description="A simple manual article drafting page for Dubai Time."
>
  <section class="section admin-shell">
    <header class="admin-header">
      <p class="eyebrow">Manual Admin</p>
      <h1>Create a Dubai Time article draft</h1>
      <p>
        Fill the story details, paste your image URL, and generate a clean markdown article
        file plus the public link format. This page does not publish by itself yet.
      </p>
    </header>

    <form class="admin-form" data-admin-form>
      <label>
        Title
        <input name="title" required placeholder="Dubai Metro update changes daily commute..." />
      </label>
      <label>
        Category
        <select name="category">
          <option>Dubai</option>
          <option>UAE</option>
          <option>Business</option>
          <option>Real Estate</option>
          <option>Travel</option>
          <option>Lifestyle</option>
          <option>Technology</option>
          <option>World</option>
        </select>
      </label>
      <label>
        Short description
        <textarea name="description" rows="3" required placeholder="One tight summary for homepage cards."></textarea>
      </label>
      <label>
        Image URL
        <input name="image" required placeholder="https://images.pexels.com/photos/..." />
      </label>
      <label>
        Image alt text
        <input name="imageAlt" required placeholder="Dubai skyline at sunset..." />
      </label>
      <label>
        Watch line
        <input name="watchLine" placeholder="Watch how this affects commuters, investors or residents." />
      </label>
      <label>
        Tags
        <input name="tags" placeholder="Dubai, Transport, RTA" />
      </label>
      <label>
        Full article body
        <textarea name="body" rows="14" required placeholder="Write or paste the full story here. Use short paragraphs."></textarea>
      </label>
      <button type="submit">Generate Article File</button>
    </form>

    <section class="admin-output" aria-label="Generated article output">
      <div>
        <p class="eyebrow">Article Link</p>
        <code data-link>/articles/your-slug</code>
      </div>
      <div>
        <p class="eyebrow">Markdown File</p>
        <textarea data-output rows="22" readonly placeholder="Your generated markdown will appear here."></textarea>
      </div>
    </section>
  </section>

  <script>
    const form = document.querySelector("[data-admin-form]");
    const output = document.querySelector("[data-output]");
    const link = document.querySelector("[data-link]");

    const slugify = (value) =>
      value
        .toLowerCase()
        .replace(/['"]/g, "")
        .replace(/[^a-z0-9]+/g, "-")
        .replace(/^-|-$/g, "")
        .slice(0, 80);

    const escapeYaml = (value) => String(value || "").replaceAll('"', '\\"');

    form?.addEventListener("submit", (event) => {
      event.preventDefault();
      const data = new FormData(form);
      const title = data.get("title");
      const slug = slugify(title);
      const today = new Intl.DateTimeFormat("en-CA", {
        timeZone: "Asia/Dubai",
        year: "numeric",
        month: "2-digit",
        day: "2-digit",
      }).format(new Date());
      const time = new Intl.DateTimeFormat("en-US", {
        timeZone: "Asia/Dubai",
        hour: "2-digit",
        minute: "2-digit",
        hour12: false,
      }).format(new Date());
      const tags = String(data.get("tags") || "")
        .split(",")
        .map((tag) => tag.trim())
        .filter(Boolean)
        .map((tag) => `"${escapeYaml(tag)}"`)
        .join(", ");

      const markdown = `---
title: "${escapeYaml(title)}"
description: "${escapeYaml(data.get("description"))}"
category: "${escapeYaml(data.get("category"))}"
author: "Dubai Time Desk"
date: ${today}
publishedTime: "${time} GST"
watchLine: "${escapeYaml(data.get("watchLine") || "Watch the next official update and public response.")}"
image: "${escapeYaml(data.get("image"))}"
imageAlt: "${escapeYaml(data.get("imageAlt"))}"
tags: [${tags}]
draft: false
---

${data.get("body")}
`;

      if (output) output.value = markdown;
      if (link) link.textContent = `/articles/${slug}`;
    });
  </script>
</BaseLayout>

<style>
  .admin-shell {
    display: grid;
    gap: 24px;
    grid-template-columns: minmax(0, 0.9fr) minmax(320px, 0.7fr);
  }

  .admin-header {
    grid-column: 1 / -1;
    max-width: 780px;
  }

  .admin-header h1 {
    font-family: Georgia, "Times New Roman", serif;
    font-size: clamp(2.4rem, 5vw, 4.8rem);
    line-height: 0.98;
    margin: 10px 0 14px;
  }

  .admin-header p:not(.eyebrow) {
    color: var(--muted);
    font-size: 1.08rem;
    line-height: 1.65;
  }

  .admin-form,
  .admin-output {
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: 8px;
    box-shadow: 0 18px 48px rgba(7, 19, 24, 0.08);
    display: grid;
    gap: 16px;
    padding: 22px;
  }

  label {
    color: var(--accent-strong);
    display: grid;
    font-size: 0.86rem;
    font-weight: 900;
    gap: 7px;
  }

  input,
  select,
  textarea {
    border: 1px solid var(--line);
    border-radius: 6px;
    color: var(--ink);
    font: inherit;
    padding: 12px;
    width: 100%;
  }

  textarea {
    line-height: 1.55;
    resize: vertical;
  }

  button {
    background: var(--accent-strong);
    border: 0;
    border-radius: 6px;
    color: #fff;
    cursor: pointer;
    font: inherit;
    font-weight: 900;
    padding: 13px 16px;
  }

  code {
    background: #f4efe4;
    border: 1px solid var(--line);
    border-radius: 6px;
    color: var(--accent-strong);
    display: block;
    font-size: 1rem;
    overflow-wrap: anywhere;
    padding: 13px;
  }

  [data-output] {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", monospace;
    font-size: 0.82rem;
  }

  @media (max-width: 860px) {
    .admin-shell {
      grid-template-columns: 1fr;
    }
  }
</style>
