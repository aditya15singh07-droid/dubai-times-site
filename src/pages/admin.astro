---
import BaseLayout from "../layouts/BaseLayout.astro";
import { categories, reportersByCategory } from "../data/articles";
---

<BaseLayout
  title="Manual Admin | Dubai Time"
  description="A private manual article drafting page for Dubai Time."
>
  <section class="section login-shell" data-login-panel>
    <form class="login-card" data-login-form>
      <p class="eyebrow">Private Access</p>
      <h1>Dubai Time Admin</h1>
      <p>Enter your admin username and password to unlock the manual article draft panel.</p>
      <label>
        Username
        <input name="username" autocomplete="username" required />
      </label>
      <label>
        Password
        <input name="password" type="password" autocomplete="current-password" required />
      </label>
      <button type="submit">Unlock Admin</button>
      <p class="login-error" data-login-error></p>
    </form>
  </section>

  <div data-admin-mount></div>

  <script define:vars={{ categories, reportersByCategory }}>
    const loginPanel = document.querySelector("[data-login-panel]");
    const loginForm = document.querySelector("[data-login-form]");
    const loginError = document.querySelector("[data-login-error]");
    const adminMount = document.querySelector("[data-admin-mount]");
    const validUsernameHash = "1c8404be8725011bb83cb1257571eb0ee8e09571c6ca031b779268b45e878d3a";
    const validPasswordHash = "0762dcffc1d8f9640a520d6317b990a7b3c6f7cd981141820ab56b548e1297b0";

    const hashText = async (value) => {
      const bytes = new TextEncoder().encode(value);
      const digest = await crypto.subtle.digest("SHA-256", bytes);
      return Array.from(new Uint8Array(digest))
        .map((byte) => byte.toString(16).padStart(2, "0"))
        .join("");
    };

    const slugify = (value) =>
      value
        .toLowerCase()
        .replace(/['"]/g, "")
        .replace(/[^a-z0-9]+/g, "-")
        .replace(/^-|-$/g, "")
        .slice(0, 80);

    const escapeYaml = (value) => String(value || "").replaceAll('"', '\\"');

    const renderAdmin = () => {
      if (!adminMount || !loginPanel) return;
      loginPanel.hidden = true;
      adminMount.innerHTML = [
        '<section class="section admin-shell" aria-label="Dubai Time manual publishing desk">',
        '<header class="admin-hero">',
        '<div>',
        '<p class="eyebrow">Manual Admin</p>',
        '<h1>Dubai Time publishing desk</h1>',
        '<p>Research the story, add a strong image, then generate a clean article file and public URL in one place.</p>',
        '</div>',
        '<button class="logout-button" type="button" data-logout>Lock Admin</button>',
        '</header>',
        '<div class="admin-steps" aria-label="Publishing workflow">',
        '<article><span>01</span><strong>Select category</strong><p>Choose the desk that fits the story.</p></article>',
        '<article><span>02</span><strong>Add article details</strong><p>Headline, summary, image and full body.</p></article>',
        '<article><span>03</span><strong>Generate file</strong><p>Copy the markdown into the site content folder.</p></article>',
        '</div>',
        '<div class="admin-layout">',
        '<form class="admin-form" data-admin-form>',
        '<div class="form-card">',
        '<p class="form-section-title">Story basics</p>',
        '<div class="field-grid">',
        '<label class="span-2">Headline<input name="title" required placeholder="Dubai Metro update changes daily commute..." /></label>',
        `<label>Category<select name="category">${categories.map((category) => `<option>${category}</option>`).join("")}</select></label>`,
        '<label>Tags<input name="tags" placeholder="Dubai, Transport, RTA" /></label>',
        '<label class="span-2">Homepage summary<textarea name="description" rows="3" required placeholder="One tight summary for homepage cards."></textarea></label>',
        '</div>',
        '</div>',
        '<div class="form-card">',
        '<p class="form-section-title">Image and reader brief</p>',
        '<div class="field-grid">',
        '<label class="span-2">Image URL<input name="image" required placeholder="https://images.pexels.com/photos/..." /></label>',
        '<label class="span-2">Image alt text<input name="imageAlt" required placeholder="Dubai skyline at sunset..." /></label>',
        '<label class="span-2">Watch line<input name="watchLine" placeholder="Watch how this affects commuters, investors or residents." /></label>',
        '</div>',
        '</div>',
        '<div class="form-card">',
        '<p class="form-section-title">Article body</p>',
        '<label>Full article body<textarea name="body" rows="18" required placeholder="Write or paste the full story here. Keep paragraphs short and useful."></textarea></label>',
        '</div>',
        '<button class="generate-button" type="submit">Generate Article File</button>',
        '</form>',
        '<section class="admin-output" aria-label="Generated article output">',
        '<div class="output-card"><p class="eyebrow">Article Link</p><code data-link>/articles/your-slug</code><small>Use this URL after the article file is committed and deployed.</small></div>',
        '<div class="output-card output-file"><p class="eyebrow">Markdown File</p><textarea data-output rows="24" readonly placeholder="Your generated markdown will appear here."></textarea></div>',
        '</section>',
        '</div>',
        '</section>',
      ].join("");

      const form = adminMount.querySelector("[data-admin-form]");
      const output = adminMount.querySelector("[data-output]");
      const link = adminMount.querySelector("[data-link]");
      const logout = adminMount.querySelector("[data-logout]");

      logout?.addEventListener("click", () => {
        window.sessionStorage.removeItem("dubai-time-admin");
        adminMount.innerHTML = "";
        loginPanel.hidden = false;
      });

      form?.addEventListener("submit", (event) => {
        event.preventDefault();
        const data = new FormData(form);
        const title = data.get("title");
        const slug = slugify(title);
        const today = new Intl.DateTimeFormat("en-CA", {
          timeZone: "Asia/Dubai",
          year: "numeric",
          month: "2-digit",
          day: "2-digit",
        }).format(new Date());
        const time = new Intl.DateTimeFormat("en-US", {
          timeZone: "Asia/Dubai",
          hour: "2-digit",
          minute: "2-digit",
          hour12: false,
        }).format(new Date());
        const tags = String(data.get("tags") || "")
          .split(",")
          .map((tag) => tag.trim())
          .filter(Boolean)
          .map((tag) => `"${escapeYaml(tag)}"`)
          .join(", ");
        const markdown = [
          "---",
          `title: "${escapeYaml(title)}"`,
          `description: "${escapeYaml(data.get("description"))}"`,
          `category: "${escapeYaml(data.get("category"))}"`,
          `author: "${escapeYaml(reportersByCategory[data.get("category")] || "Dubai Time Desk")}"`,
          `date: ${today}`,
          `publishedTime: "${time} GST"`,
          `watchLine: "${escapeYaml(data.get("watchLine") || "Watch the next official update and public response.")}"`,
          `image: "${escapeYaml(data.get("image"))}"`,
          `imageAlt: "${escapeYaml(data.get("imageAlt"))}"`,
          `tags: [${tags}]`,
          "draft: false",
          "---",
          "",
          data.get("body"),
          "",
        ].join("\n");

        if (output) output.value = markdown;
        if (link) link.textContent = `/articles/${slug}`;
      });
    };

    if (window.sessionStorage.getItem("dubai-time-admin") === "unlocked") {
      renderAdmin();
    }

    loginForm?.addEventListener("submit", async (event) => {
      event.preventDefault();
      const data = new FormData(loginForm);
      const usernameHash = await hashText(String(data.get("username") || ""));
      const passwordHash = await hashText(String(data.get("password") || ""));
      const ok = usernameHash === validUsernameHash && passwordHash === validPasswordHash;

      if (!ok) {
        if (loginError) loginError.textContent = "Wrong username or password.";
        return;
      }

      if (loginError) loginError.textContent = "";
      loginForm.reset();
      window.sessionStorage.setItem("dubai-time-admin", "unlocked");
      renderAdmin();
    });
  </script>
</BaseLayout>

<style is:global>
  .login-shell {
    max-width: 620px;
    min-height: 68vh;
  }

  .login-card {
    backdrop-filter: blur(20px) saturate(1.14);
    background:
      linear-gradient(135deg, rgba(255, 255, 255, 0.92), rgba(255, 255, 255, 0.56));
    border: 1px solid rgba(222, 216, 205, 0.78);
    border-radius: 12px;
    box-shadow: 0 24px 70px rgba(7, 19, 24, 0.11);
    display: grid;
    gap: 16px;
    padding: 28px;
  }

  .login-card h1 {
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
      sans-serif;
    font-size: clamp(1.45rem, 3.2vw, 2.3rem);
    line-height: 1.12;
    margin: 0;
  }

  .login-card p:not(.eyebrow):not(.login-error) {
    color: var(--muted);
    line-height: 1.6;
    margin: 0;
  }

  .login-error {
    color: #b42318;
    font-size: 0.9rem;
    font-weight: 800;
    margin: 0;
    min-height: 1.2em;
  }

  .admin-shell {
    display: grid;
    gap: 22px;
  }

  .admin-hero {
    align-items: end;
    background:
      linear-gradient(135deg, rgba(255, 255, 255, 0.92), rgba(248, 245, 238, 0.72)),
      radial-gradient(circle at 88% 16%, rgba(194, 145, 45, 0.16), transparent 28%);
    border: 1px solid rgba(222, 216, 205, 0.85);
    border-radius: 14px;
    box-shadow: 0 24px 70px rgba(7, 19, 24, 0.08);
    display: flex;
    gap: 24px;
    justify-content: space-between;
    padding: 28px;
  }

  .admin-hero h1 {
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
      sans-serif;
    font-size: clamp(1.5rem, 3vw, 2.4rem);
    line-height: 1.12;
    margin: 10px 0 14px;
  }

  .admin-hero p:not(.eyebrow) {
    color: var(--muted);
    font-size: 0.98rem;
    line-height: 1.65;
    margin: 0;
    max-width: 760px;
  }

  .logout-button {
    background: #111;
    flex: 0 0 auto;
    width: fit-content;
  }

  .admin-steps {
    display: grid;
    gap: 14px;
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .admin-steps article {
    background: rgba(255, 255, 255, 0.72);
    border: 1px solid rgba(222, 216, 205, 0.78);
    border-radius: 12px;
    box-shadow: 0 16px 44px rgba(7, 19, 24, 0.06);
    padding: 18px;
  }

  .admin-steps span {
    color: var(--gold);
    display: block;
    font-size: 0.78rem;
    font-weight: 950;
    letter-spacing: 0.12em;
    margin-bottom: 10px;
  }

  .admin-steps strong {
    color: var(--accent-strong);
    display: block;
    font-size: 1rem;
    margin-bottom: 6px;
  }

  .admin-steps p {
    color: var(--muted);
    font-size: 0.92rem;
    line-height: 1.5;
    margin: 0;
  }

  .admin-layout {
    align-items: start;
    display: grid;
    gap: 22px;
    grid-template-columns: minmax(0, 1.05fr) minmax(340px, 0.72fr);
  }

  .admin-form,
  .admin-output {
    display: grid;
    gap: 16px;
  }

  .form-card,
  .output-card {
    backdrop-filter: blur(18px);
    background:
      linear-gradient(135deg, rgba(255, 255, 255, 0.94), rgba(255, 255, 255, 0.68));
    border: 1px solid rgba(222, 216, 205, 0.82);
    border-radius: 12px;
    box-shadow: 0 18px 48px rgba(7, 19, 24, 0.08);
    padding: 20px;
  }

  .form-section-title {
    color: var(--accent);
    font-size: 0.78rem;
    font-weight: 950;
    letter-spacing: 0.1em;
    margin: 0 0 16px;
    text-transform: uppercase;
  }

  .field-grid {
    display: grid;
    gap: 16px;
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .span-2 {
    grid-column: 1 / -1;
  }

  .admin-shell label,
  .login-card label {
    color: var(--accent-strong);
    display: grid;
    font-size: 0.86rem;
    font-weight: 900;
    gap: 7px;
  }

  .admin-shell input,
  .admin-shell select,
  .admin-shell textarea,
  .login-card input {
    background: rgba(255, 255, 255, 0.9);
    border: 1px solid var(--line);
    border-radius: 9px;
    color: var(--ink);
    font: inherit;
    padding: 12px;
    width: 100%;
  }

  .admin-shell input:focus,
  .admin-shell select:focus,
  .admin-shell textarea:focus,
  .login-card input:focus {
    border-color: var(--accent);
    box-shadow: 0 0 0 4px rgba(11, 110, 105, 0.12);
    outline: none;
  }

  .admin-shell textarea {
    line-height: 1.55;
    resize: vertical;
  }

  .admin-shell button,
  .login-card button {
    background: var(--accent-strong);
    border: 0;
    border-radius: 9px;
    color: #fff;
    cursor: pointer;
    font: inherit;
    font-weight: 900;
    padding: 13px 16px;
  }

  .generate-button {
    box-shadow: 0 14px 32px rgba(8, 76, 97, 0.18);
    min-height: 52px;
  }

  .admin-shell code {
    background: #f4efe4;
    border: 1px solid var(--line);
    border-radius: 9px;
    color: var(--accent-strong);
    display: block;
    font-size: 1rem;
    overflow-wrap: anywhere;
    padding: 13px;
  }

  .output-card small {
    color: var(--muted);
    display: block;
    font-size: 0.84rem;
    line-height: 1.5;
    margin-top: 10px;
  }

  .output-file {
    position: sticky;
    top: 110px;
  }

  [data-output] {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", monospace;
    font-size: 0.82rem;
  }

  @media (max-width: 860px) {
    .admin-hero {
      align-items: flex-start;
      flex-direction: column;
    }

    .admin-steps,
    .admin-layout {
      grid-template-columns: 1fr;
    }

    .output-file {
      position: static;
    }
  }

  @media (max-width: 560px) {
    .admin-hero,
    .form-card,
    .output-card {
      padding: 18px;
    }

    .field-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
