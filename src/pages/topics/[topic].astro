---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { seoTopics, topicPath } from "../../data/topics";
import { optimizedImage } from "../../lib/images";

export async function getStaticPaths() {
  return seoTopics.map((topic) => ({
    params: { topic: topic.slug },
    props: { topic },
  }));
}

const articleTimestamp = (entry) => {
  const [hour = "00", minute = "00"] = String(entry.data.publishedTime || "").match(/\d{2}/g) || [];
  const date = new Date(entry.data.date);
  date.setHours(Number(hour), Number(minute), 0, 0);
  return date.getTime();
};

const { topic } = Astro.props;
const allArticles = (await getCollection("articles", ({ data }) => !data.draft))
  .sort((a, b) => articleTimestamp(b) - articleTimestamp(a));

const topicWords = topic.keywords.map((keyword) => keyword.toLowerCase());
const topicArticles = allArticles
  .filter((article) => {
    const haystack = `${article.data.title} ${article.data.description} ${article.data.category} ${article.data.tags.join(" ")}`.toLowerCase();
    return topicWords.some((keyword) => haystack.includes(keyword.split(" ")[0]) || haystack.includes(keyword));
  })
  .slice(0, 24);

const fallbackArticles = allArticles
  .filter((article) => !topicArticles.some((match) => match.id === article.id))
  .slice(0, Math.max(0, 12 - topicArticles.length));
const articles = [...topicArticles, ...fallbackArticles];
const [leadArticle, ...restArticles] = articles;
const canonical = `https://dubai-time.com${topicPath(topic.slug)}`;

const pageJsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    name: topic.title,
    url: canonical,
    description: topic.description,
    about: topic.keywords,
    isPartOf: {
      "@type": "WebSite",
      name: "Dubai Time",
      url: "https://dubai-time.com",
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "ItemList",
    name: `${topic.title} latest stories`,
    itemListElement: articles.slice(0, 12).map((article, index) => ({
      "@type": "ListItem",
      position: index + 1,
      url: `https://dubai-time.com/articles/${article.id}`,
      name: article.data.title,
    })),
  },
];
---

<BaseLayout
  title={`${topic.title} | Dubai Time`}
  description={topic.description}
  canonical={canonical}
  structuredData={pageJsonLd}
>
  <section class="section topic-page">
    <header class="topic-header">
      <p class="eyebrow">Dubai Time Topic Hub</p>
      <h1>{topic.title}</h1>
      <p>{topic.description}</p>
      <div class="keyword-row" aria-label="Related search themes">
        {topic.keywords.map((keyword) => <span>{keyword}</span>)}
      </div>
    </header>

    {leadArticle && (
      <article class="topic-lead">
        <a href={`/articles/${leadArticle.id}`}>
          <img src={optimizedImage(leadArticle.data.image)} alt={leadArticle.data.imageAlt} />
        </a>
        <div>
          <p class="eyebrow">{leadArticle.data.category}</p>
          <h2><a href={`/articles/${leadArticle.id}`}>{leadArticle.data.title}</a></h2>
          <p>{leadArticle.data.description}</p>
          <small>{leadArticle.data.publishedTime}</small>
        </div>
      </article>
    )}

    <div class="topic-grid">
      {restArticles.map((article) => (
        <a href={`/articles/${article.id}`} class="topic-card">
          <img src={optimizedImage(article.data.image)} alt={article.data.imageAlt} loading="lazy" />
          <span>{article.data.category}</span>
          <strong>{article.data.title}</strong>
          <small>{article.data.publishedTime}</small>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .topic-header {
    border-bottom: 1px solid var(--line);
    margin-bottom: 28px;
    padding-bottom: 22px;
  }

  .topic-header h1 {
    font-size: clamp(1.55rem, 3vw, 2.4rem);
    line-height: 1.1;
    margin: 10px 0;
  }

  .topic-header p:not(.eyebrow) {
    color: var(--muted);
    font-size: 1rem;
    font-weight: 750;
    line-height: 1.55;
    max-width: 760px;
  }

  .keyword-row {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 18px;
  }

  .keyword-row span {
    background: #111214;
    color: #fff;
    font-size: 0.72rem;
    font-weight: 950;
    letter-spacing: 0.04em;
    padding: 8px 10px;
    text-transform: uppercase;
  }

  .topic-lead {
    background: #111214;
    color: #fff;
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(300px, 0.75fr);
    margin-bottom: 24px;
  }

  .topic-lead img {
    aspect-ratio: 16 / 9;
    height: 100%;
    object-fit: cover;
  }

  .topic-lead div {
    align-self: center;
    padding: clamp(22px, 4vw, 42px);
  }

  .topic-lead h2 {
    font-size: clamp(1.1rem, 2vw, 1.55rem);
    line-height: 1.18;
    margin: 10px 0;
  }

  .topic-lead p:not(.eyebrow) {
    color: rgba(255, 255, 255, 0.78);
    line-height: 1.55;
  }

  .topic-grid {
    display: grid;
    gap: 18px;
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .topic-card {
    background: var(--panel);
    border: 1px solid var(--line);
    display: grid;
    gap: 10px;
    padding-bottom: 16px;
  }

  .topic-card img {
    aspect-ratio: 16 / 10;
    object-fit: cover;
    width: 100%;
  }

  .topic-card span,
  .topic-card small {
    color: var(--accent);
    font-size: 0.72rem;
    font-weight: 950;
    letter-spacing: 0.06em;
    padding: 0 16px;
    text-transform: uppercase;
  }

  .topic-card strong {
    font-size: 1rem;
    line-height: 1.22;
    padding: 0 16px;
  }

  .topic-card small {
    color: var(--soft);
  }

  @media (max-width: 900px) {
    .topic-lead,
    .topic-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
