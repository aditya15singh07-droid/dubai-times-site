---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { categories, categoryPath } from "../../data/articles";
import { optimizedImage } from "../../lib/images";

export async function getStaticPaths() {
  return categories.map((category) => ({
    params: { category: categoryPath(category) },
    props: { category },
  }));
}

const articleTimestamp = (entry) => {
  const [hour = "00", minute = "00"] = String(entry.data.publishedTime || "").match(/\d{2}/g) || [];
  const date = new Date(entry.data.date);
  date.setHours(Number(hour), Number(minute), 0, 0);
  return date.getTime();
};

const { category } = Astro.props;
const canonical = `https://dubai-time.com/category/${categoryPath(category)}`;
const articles = await getCollection("articles", ({ data }) => !data.draft);
const categoryArticles = articles
  .filter((article) => article.data.category.toLowerCase() === category.toLowerCase())
  .sort((a, b) => articleTimestamp(b) - articleTimestamp(a));

const [leadArticle, ...restArticles] = categoryArticles;
const categoryJsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    name: `${category} News`,
    url: canonical,
    description: `Latest ${category} coverage from Dubai Time with UAE-first context and live updates.`,
    isPartOf: {
      "@type": "WebSite",
      name: "Dubai Time",
      url: "https://dubai-time.com",
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "ItemList",
    name: `${category} latest stories`,
    itemListElement: categoryArticles.slice(0, 12).map((article, index) => ({
      "@type": "ListItem",
      position: index + 1,
      url: `https://dubai-time.com/articles/${article.id}`,
      name: article.data.title,
    })),
  },
];
---

<BaseLayout
  title={`${category} News | Dubai Time`}
  description={`Latest ${category} coverage from Dubai Time with UAE-first context, live updates and reader-friendly explainers.`}
  canonical={canonical}
  structuredData={categoryJsonLd}
>
  <section class="section category-page">
    <header class="category-header">
      <p class="eyebrow">Dubai Time Section</p>
      <h1>{category}</h1>
      <p>Sharp, UAE-first coverage from the {category} desk.</p>
    </header>

    {leadArticle ? (
      <article class="category-lead">
        <a href={`/articles/${leadArticle.id}`}>
          <img src={optimizedImage(leadArticle.data.image)} alt={leadArticle.data.imageAlt} />
        </a>
        <div>
          <p class="eyebrow">{leadArticle.data.category}</p>
          <h2><a href={`/articles/${leadArticle.id}`}>{leadArticle.data.title}</a></h2>
          <p>{leadArticle.data.description}</p>
          <small>{leadArticle.data.publishedTime}</small>
        </div>
      </article>
    ) : (
      <p class="empty">This section is ready. Articles will appear here as the Dubai Time engine starts publishing.</p>
    )}

    <div class="listing">
      {restArticles.map((article) => (
        <article class="row">
          <a href={`/articles/${article.id}`}>
            <img src={optimizedImage(article.data.image)} alt={article.data.imageAlt} loading="lazy" />
          </a>
          <div>
            <p class="eyebrow">{article.data.category}</p>
            <h2><a href={`/articles/${article.id}`}>{article.data.title}</a></h2>
            <p>{article.data.description}</p>
            <small>{article.data.publishedTime}</small>
          </div>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .category-header {
    border-bottom: 1px solid var(--line);
    margin-bottom: 26px;
    padding-bottom: 22px;
  }

  h1 {
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
      sans-serif;
    font-size: clamp(1.45rem, 3vw, 2.15rem);
    letter-spacing: -0.02em;
    line-height: 1.12;
    margin: 10px 0;
  }

  .category-header p:not(.eyebrow) {
    color: var(--muted);
    font-size: 1rem;
    font-weight: 700;
  }

  .category-lead {
    background: #111214;
    color: #fff;
    display: grid;
    gap: 0;
    grid-template-columns: minmax(0, 1.1fr) minmax(320px, 0.72fr);
    margin-bottom: 24px;
  }

  .category-lead img {
    aspect-ratio: 16 / 10;
    height: 100%;
    object-fit: cover;
  }

  .category-lead div {
    align-self: center;
    padding: clamp(24px, 4vw, 42px);
  }

  .category-lead h2 {
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
      sans-serif;
    font-size: clamp(1.05rem, 1.8vw, 1.45rem);
    line-height: 1.18;
    margin: 10px 0 14px;
  }

  .category-lead p:not(.eyebrow) {
    color: rgba(255, 255, 255, 0.76);
    line-height: 1.6;
  }

  .category-lead small,
  .row small {
    color: var(--soft);
    font-size: 0.76rem;
    font-weight: 900;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .listing {
    display: grid;
    gap: 18px;
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .row {
    background: var(--panel);
    border: 1px solid var(--line);
    display: grid;
    gap: 0;
    grid-template-columns: 190px 1fr;
    overflow: hidden;
  }

  .row img {
    aspect-ratio: 4 / 3;
    height: 100%;
    object-fit: cover;
  }

  .row div {
    align-self: center;
    padding: 18px;
  }

  .row h2 {
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
      sans-serif;
    font-size: 0.95rem;
    line-height: 1.22;
    margin: 8px 0 10px;
  }

  .row h2 a:hover,
  .category-lead h2 a:hover {
    color: var(--accent);
  }

  .row p:not(.eyebrow),
  .empty {
    color: var(--muted);
    hyphens: none;
    line-height: 1.55;
    overflow-wrap: normal;
    text-align: justify;
    text-justify: inter-word;
    word-break: normal;
  }

  @media (max-width: 900px) {
    .category-lead,
    .listing {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 620px) {
    .row {
      grid-template-columns: 1fr;
    }
  }
</style>
