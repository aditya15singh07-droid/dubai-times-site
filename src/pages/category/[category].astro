---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { articles, categories, getArticlesByCategory } from "../../data/articles";

export function getStaticPaths() {
  return categories.map((category) => ({
    params: { category: category.toLowerCase().replaceAll(" ", "-") },
    props: { category },
  }));
}

const { category } = Astro.props;
const categoryArticles = getArticlesByCategory(category);
---

<BaseLayout
  title={`${category} News | Dubai Times`}
  description={`Latest ${category} coverage from Dubai Times.`}
>
  <section class="section">
    <header class="category-header">
      <p class="eyebrow">Section</p>
      <h1>{category}</h1>
      <p>Latest Dubai Times coverage from the {category} desk.</p>
    </header>

    <div class="listing">
      {categoryArticles.length > 0 ? (
        categoryArticles.map((article) => (
          <article class="row">
            <a href={`/articles/${article.slug}`}>
              <img src={article.image} alt={article.imageAlt} loading="lazy" />
            </a>
            <div>
              <p class="eyebrow">{article.category}</p>
              <h2><a href={`/articles/${article.slug}`}>{article.title}</a></h2>
              <p>{article.description}</p>
            </div>
          </article>
        ))
      ) : (
        <p class="empty">This section is ready. Articles will appear here as the Dubai Times engine starts publishing.</p>
      )}
    </div>
  </section>
</BaseLayout>

<style>
  .category-header {
    border-bottom: 1px solid var(--line);
    margin-bottom: 26px;
    padding-bottom: 22px;
  }

  h1 {
    font-family: Georgia, "Times New Roman", serif;
    font-size: clamp(2.6rem, 6vw, 5rem);
    line-height: 1;
    margin: 10px 0;
  }

  .category-header p:not(.eyebrow) {
    color: var(--muted);
    font-size: 1.1rem;
  }

  .listing {
    display: grid;
    gap: 22px;
  }

  .row {
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: 6px;
    display: grid;
    gap: 22px;
    grid-template-columns: 260px 1fr;
    overflow: hidden;
  }

  .row img {
    aspect-ratio: 4 / 3;
    height: 100%;
    object-fit: cover;
  }

  .row div {
    align-self: center;
    padding: 18px 20px 18px 0;
  }

  .row h2 {
    font-family: Georgia, "Times New Roman", serif;
    font-size: 1.7rem;
    line-height: 1.12;
    margin: 8px 0 10px;
  }

  .row p:not(.eyebrow),
  .empty {
    color: var(--muted);
    line-height: 1.6;
  }

  @media (max-width: 700px) {
    .row {
      grid-template-columns: 1fr;
    }

    .row div {
      padding: 0 18px 18px;
    }
  }
</style>
