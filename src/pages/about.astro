---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="About Dubai Time"
  description="Dubai Time is being built as a live UAE time, weather, alerts, and news publication."
>
  <section class="section about">
    <p class="eyebrow">About</p>
    <h1>Dubai Time is being built as a modern time, weather and news desk.</h1>
    <p>
      The homepage now starts with live UAE time, seven-emirate weather,
      rain signals and alerts. News remains part of the product, but the main
      identity is time-first, useful and quick to understand.
    </p>
    <div class="principles">
      <section>
        <h2>Coverage</h2>
        <p>Dubai, UAE business, real estate, travel, lifestyle, technology, and regional stories.</p>
      </section>
      <section>
        <h2>Style</h2>
        <p>Clear, useful, polished news writing without fake quotes or unsupported claims.</p>
      </section>
      <section>
        <h2>System</h2>
        <p>Static website first, private automation engine later, with GitHub and Vercel deployment.</p>
      </section>
    </div>
  </section>
</BaseLayout>

<style>
  .about {
    max-width: 960px;
  }

  h1 {
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
      sans-serif;
    font-size: clamp(1.5rem, 3.2vw, 2.4rem);
    line-height: 1.12;
    margin: 12px 0 20px;
  }

  .about > p:not(.eyebrow) {
    color: var(--muted);
    font-size: 1rem;
    line-height: 1.75;
    max-width: 760px;
  }

  .principles {
    display: grid;
    gap: 18px;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    margin-top: 34px;
  }

  .principles section {
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: 6px;
    padding: 20px;
  }

  .principles h2 {
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
      sans-serif;
    font-size: 1rem;
    margin: 0 0 10px;
  }

  .principles p {
    color: var(--muted);
    line-height: 1.6;
    margin: 0;
  }

  @media (max-width: 780px) {
    .principles {
      grid-template-columns: 1fr;
    }
  }
</style>
